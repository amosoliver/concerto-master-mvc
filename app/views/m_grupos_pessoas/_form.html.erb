<%= form_with(model: m_grupo_pessoa, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: m_grupo_pessoa %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :g_pessoa_id %>
      <%= form.collection_select :g_pessoa_id, tenant_pessoa_scope, :id, :to_s, { include_blank: "Selecione uma pessoa..." }, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :m_grupo_id %>
      <%= form.collection_select :m_grupo_id, tenant_grupo_scope, :id, :to_s, { include_blank: "Selecione um grupo..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", m_grupo_pessoa_path(@m_grupo_pessoa), class: "secondary-button" if m_grupo_pessoa.persisted? %>
    <%= link_to "Cancelar", m_grupos_pessoas_path, class: "secondary-button" unless m_grupo_pessoa.persisted? %>
  </div>
<% end %>
