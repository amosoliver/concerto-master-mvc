<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MEnsaioMusica.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= link_to "Editar", edit_m_ensaio_musica_path(@m_ensaio_musica), class: "primary-button" %>
      <%= link_to "Voltar", m_ensaio_musicas_path, class: "secondary-button" %>
    </div>
  </div>

  <% evento_musica = @m_ensaio_musica.m_evento_musica %>
  <% evento = evento_musica&.m_evento %>
  <% musica = evento_musica&.m_musica %>

  <div class="show-stack">
    <div class="show-hero">
      <section class="panel-card show-summary">
        <p class="eyebrow">Repertório do ensaio</p>
        <h2 class="show-summary__title"><%= musica&.descricao || "Música vinculada" %></h2>
        <p class="show-summary__text">
          Música planejada no ensaio <%= @m_ensaio_musica.m_ensaio %>
          <%= "para o evento #{evento}" if evento.present? %>.
        </p>
      </section>

      <section class="panel-card show-section">
        <div class="panel-card__header">
          <div>
            <p class="eyebrow">Resumo</p>
            <h3>Contexto</h3>
          </div>
        </div>
        <div class="show-stats">
          <div class="show-stat">
            <span class="show-stat__label">Ensaio</span>
            <span class="show-stat__value"><%= @m_ensaio_musica.m_ensaio %></span>
          </div>
          <div class="show-stat">
            <span class="show-stat__label">Evento</span>
            <span class="show-stat__value"><%= evento || "-" %></span>
          </div>
        </div>
      </section>
    </div>

    <section class="panel-card detail-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Informações</p>
          <h3><%= MEnsaioMusica.model_name.human %></h3>
        </div>
      </div>

      <div class="detail-grid">
        <div class="detail-tile">
          <span class="detail-label"><%= MEnsaioMusica.human_attribute_name(:m_ensaio_id) %></span>
          <span class="detail-value"><%= @m_ensaio_musica.m_ensaio %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MEnsaioMusica.human_attribute_name(:m_evento_musica_id) %></span>
          <span class="detail-value"><%= @m_ensaio_musica.m_evento_musica %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MEnsaioMusica.human_attribute_name(:g_entidade_id) %></span>
          <span class="detail-value"><%= @m_ensaio_musica.g_entidade %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MEnsaioMusica.human_attribute_name(:observacao) %></span>
          <span class="detail-value"><%= @m_ensaio_musica.observacao.presence || "Sem observação" %></span>
        </div>
      </div>

      <div class="detail-meta">
        <span>Criado em <%= l(@m_ensaio_musica.created_at) %></span>
        <span>Atualizado em <%= l(@m_ensaio_musica.updated_at) %></span>
      </div>
    </section>

    <section class="panel-card show-section">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Relacionados</p>
          <h3>Navegação rápida</h3>
        </div>
      </div>
      <div class="related-grid">
        <article class="related-card">
          <span class="related-card__label">Ensaio</span>
          <%= link_to @m_ensaio_musica.m_ensaio, m_ensaio_path(@m_ensaio_musica.m_ensaio), class: "related-card__value related-card__value--link" %>
          <span class="related-card__meta"><%= @m_ensaio_musica.m_ensaio.data_inicio.present? ? l(@m_ensaio_musica.m_ensaio.data_inicio) : "Sem data" %></span>
        </article>

        <% if evento.present? %>
          <article class="related-card">
            <span class="related-card__label">Evento</span>
            <%= link_to evento, m_evento_path(evento), class: "related-card__value related-card__value--link" %>
            <span class="related-card__meta"><%= evento.data_inicio.present? ? l(evento.data_inicio) : "Sem data" %></span>
          </article>
        <% end %>

        <% if musica.present? %>
          <article class="related-card">
            <span class="related-card__label">Música</span>
            <%= link_to musica, m_musica_path(musica), class: "related-card__value related-card__value--link" %>
            <span class="related-card__meta"><%= [musica.m_artista, musica.m_compositor].compact.join(" • ").presence || "Sem informações complementares" %></span>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</div>
