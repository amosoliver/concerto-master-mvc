<aside class="sidebar" data-sidebar-target="panel">
  <div class="sidebar__brand">
    <%= link_to root_path, class: "sidebar__brand-link" do %>
      <div class="brand-mark"><%= render "layouts/brand_mark" %></div>
      <div>
        <h1>Concert Master</h1>
      </div>
    <% end %>
    <button type="button" class="sidebar-close" data-action="click->sidebar#close" aria-label="Fechar menu">✕</button>
  </div>

  <nav class="sidebar__nav" aria-label="Menu principal">
    <% sidebar_nav_groups.each do |group| %>
      <% next if Array(group[:items]).blank? %>

      <div class="sidebar-group">
        <% if group[:label] && group[:items] %>
          <details class="sidebar-module" <%= "open" if group[:expanded] %>>
            <summary class="sidebar-module__summary">
              <span class="sidebar-module__title-wrap">
                <span class="sidebar-module__icon"><%= group[:icon] %></span>
                <span class="sidebar-module__title"><%= group[:label] %></span>
              </span>
              <span class="sidebar-module__chevron" aria-hidden="true">⌄</span>
            </summary>

            <div class="sidebar-module__content">
              <% group[:items].each do |item| %>
                <%= render "layouts/sidebar_item", item: item %>
              <% end %>
            </div>
          </details>
        <% else %>
          <% group[:items].each do |item| %>
            <%= render "layouts/sidebar_item", item: item %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </nav>
</aside>
