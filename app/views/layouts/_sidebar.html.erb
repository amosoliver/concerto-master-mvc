<aside class="sidebar" data-sidebar-target="panel">
  <div class="sidebar__brand">
    <div class="brand-mark">🎵</div>
    <div>
      <h1>Concreto Master</h1>
      <p>Sistema de Música</p>
    </div>
    <button type="button" class="sidebar-close" data-action="click->sidebar#close" aria-label="Fechar menu">✕</button>
  </div>

  <nav class="sidebar__nav" aria-label="Menu principal">
    <% sidebar_nav_groups.each do |group| %>
      <div class="sidebar-group">
        <% if group[:label] %>
          <p class="sidebar-group__title"><%= group[:label] %></p>
        <% end %>

        <% if group[:subgroups] %>
          <% group[:subgroups].each do |subgroup| %>
            <div class="sidebar-subgroup">
              <p class="sidebar-subgroup__title"><%= subgroup[:label] %></p>
              <% subgroup[:items].each do |item| %>
                <%= render "layouts/sidebar_item", item: item %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <% group[:items].each do |item| %>
            <%= render "layouts/sidebar_item", item: item %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </nav>
</aside>
