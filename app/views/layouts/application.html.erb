<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
  <head>
    <title><%= content_for(:title) || "Concreto Master" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Concreto Master">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="Sistema premium de gestão musical para igrejas.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%# Vendored as a plain UMD bundle (not import-mapped): it ships unbundled
        ESM source with relative imports between its own files, which only
        resolve when served from its own CDN tree, not once downloaded. %>
    <%= javascript_include_tag "tom-select", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "layouts/flash" %>

    <div class="dashboard-shell" data-controller="theme sidebar">
      <%= render "layouts/sidebar" %>
      <div class="sidebar-overlay" data-sidebar-target="overlay" data-action="click->sidebar#close"></div>

      <div class="main-panel">
        <%= render "layouts/topbar" %>

        <main class="content">
          <%= render "layouts/breadcrumb" %>
          <section class="content-frame">
            <%= yield %>
          </section>
        </main>
      </div>

      <%= render "layouts/mobile_nav" %>
    </div>
  </body>
</html>
