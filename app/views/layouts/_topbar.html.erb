<header class="topbar">
  <div class="topbar__primary">
    <button type="button" class="sidebar-toggle" data-sidebar-target="toggle" data-action="click->sidebar#toggle" aria-label="Abrir menu" aria-expanded="false">☰</button>
    <label class="searchbox" aria-label="Buscar">
      <span>🔎</span>
      <input type="search" placeholder="Buscar músicas, eventos, usuários..." />
    </label>
  </div>

  <div class="topbar__actions">
    <button class="icon-button" aria-label="Notificações">🔔</button>
    <button class="icon-button" data-action="click->theme#toggle" aria-label="Alternar tema">
      <span data-theme-target="themeIcon">🌙</span>
    </button>
    <button class="icon-button" aria-label="Ajuda">❓</button>
    <% if g_usuario_signed_in? %>
      <div class="actions-menu" data-controller="dropdown">
        <button type="button" class="avatar-pill" data-dropdown-target="button" data-action="click->dropdown#toggle" aria-haspopup="true" aria-expanded="false">
          <div class="avatar"><%= current_g_usuario.g_pessoa.nome.to_s.first(2).upcase %></div>
          <div>
            <strong><%= current_g_usuario.g_pessoa.nome %></strong>
            <small><%= current_g_usuario.email %></small>
          </div>
        </button>
        <div class="actions-menu__panel" data-dropdown-target="panel" hidden>
          <%= button_to destroy_g_usuario_session_path, method: :delete, class: "actions-menu__item" do %><span aria-hidden="true">🚪</span> Sair<% end %>
        </div>
      </div>
    <% end %>
  </div>
</header>
