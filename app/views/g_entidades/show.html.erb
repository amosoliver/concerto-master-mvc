<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= GEntidade.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_g_entidade_path(@g_entidade), class: "primary-button" %>
      <%= link_to "Voltar", g_entidades_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= GEntidade.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= GEntidade.human_attribute_name(:descricao) %></span>
        <span class="detail-value"><%= @g_entidade.descricao %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= GEntidade.human_attribute_name(:g_estado_id) %></span>
        <span class="detail-value"><%= @g_entidade.g_estado %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= GEntidade.human_attribute_name(:g_municipio_id) %></span>
        <span class="detail-value"><%= @g_entidade.g_municipio %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= GEntidade.human_attribute_name(:g_entidade_id) %></span>
        <span class="detail-value"><%= @g_entidade.g_entidade %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@g_entidade.created_at) %></span>
      <span>Atualizado em <%= l(@g_entidade.updated_at) %></span>
    </div>
  </section>
</div>
