<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(UPerfilPermissao) %></h1>
    </div>
    <div class="page-header__actions">
      <%= link_to "Novo #{UPerfilPermissao.model_name.human}", new_u_perfil_permissao_path, class: "primary-button" %>
    </div>
  </div>

  <%= search_form_for @q, url: u_perfis_permissoes_path, method: :get, class: "search-panel" do |f| %>
    <div class="search-input">
      <span aria-hidden="true">🔎</span>
      <%= f.select :u_perfil_id_eq, options_from_collection_for_select(UPerfil.all, :id, :to_s, @q&.send(:u_perfil_id_eq)), { include_blank: true }, "aria-label": UPerfilPermissao.human_attribute_name(:u_perfil_id), class: "search-input__field" %>
    </div>
    <div class="search-input">
      <span aria-hidden="true">🔎</span>
      <%= f.select :u_permissao_id_eq, options_from_collection_for_select(UPermissao.all, :id, :to_s, @q&.send(:u_permissao_id_eq)), { include_blank: true }, "aria-label": UPerfilPermissao.human_attribute_name(:u_permissao_id), class: "search-input__field" %>
    </div>
    <div class="search-panel__actions">
      <%= f.submit "Filtrar", class: "primary-button" %>
      <%= link_to "Limpar", u_perfis_permissoes_path, class: "secondary-button" %>
    </div>
  <% end %>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@u_perfis_permissoes.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= UPerfilPermissao.human_attribute_name(:u_perfil_id) %></th>
            <th scope="col"><%= UPerfilPermissao.human_attribute_name(:u_permissao_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @u_perfis_permissoes.each do |u_perfil_permissao| %>
            <tr>
              <td><%= u_perfil_permissao.u_perfil %></td>
              <td><%= u_perfil_permissao.u_permissao %></td>
              <td>
                <%= render "shared/actions_menu", show_path: u_perfil_permissao_path(u_perfil_permissao), edit_path: edit_u_perfil_permissao_path(u_perfil_permissao), delete_path: u_perfil_permissao_path(u_perfil_permissao) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @u_perfis_permissoes.each do |u_perfil_permissao| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= UPerfilPermissao.human_attribute_name(:u_perfil_id) %></span>
            <span class="detail-value"><%= u_perfil_permissao.u_perfil %></span>
            <span class="detail-label"><%= UPerfilPermissao.human_attribute_name(:u_permissao_id) %></span>
            <span class="detail-value"><%= u_perfil_permissao.u_permissao %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: u_perfil_permissao_path(u_perfil_permissao), edit_path: edit_u_perfil_permissao_path(u_perfil_permissao), delete_path: u_perfil_permissao_path(u_perfil_permissao) %>
          </div>
        </article>
      <% end %>
    </div>

    <% if @pagy %>
      <div class="pagination-wrap">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  </section>
</div>
