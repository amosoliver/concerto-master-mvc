<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= UPerfilPermissao.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_u_perfil_permissao_path(@u_perfil_permissao), class: "primary-button" %>
      <%= link_to "Voltar", u_perfis_permissoes_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= UPerfilPermissao.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= UPerfilPermissao.human_attribute_name(:u_perfil_id) %></span>
        <span class="detail-value"><%= @u_perfil_permissao.u_perfil %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= UPerfilPermissao.human_attribute_name(:u_permissao_id) %></span>
        <span class="detail-value"><%= @u_perfil_permissao.u_permissao %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@u_perfil_permissao.created_at) %></span>
      <span>Atualizado em <%= l(@u_perfil_permissao.updated_at) %></span>
    </div>
  </section>
</div>
