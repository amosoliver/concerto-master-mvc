<%= form_with(model: u_perfil_permissao, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: u_perfil_permissao %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :u_perfil_id %>
      <%= form.collection_select :u_perfil_id, UPerfil.all, :id, :to_s, { include_blank: "Selecione um perfil..." }, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :u_permissao_id %>
      <%= form.collection_select :u_permissao_id, UPermissao.all, :id, :to_s, { include_blank: "Selecione uma permissão..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", u_perfil_permissao_path(@u_perfil_permissao), class: "secondary-button" if u_perfil_permissao.persisted? %>
    <%= link_to "Cancelar", u_perfis_permissoes_path, class: "secondary-button" unless u_perfil_permissao.persisted? %>
  </div>
<% end %>
