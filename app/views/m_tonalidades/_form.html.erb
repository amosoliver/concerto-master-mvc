<%= form_with(model: m_tonalidade, local: true, class: "panel-card form-card") do |form| %>
  <% if m_tonalidade.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= pluralize(m_tonalidade.errors.count, "erro") %> impediram o salvamento:</h2>
      <ul>
        <% m_tonalidade.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", m_tonalidade_path(@m_tonalidade), class: "secondary-button" if m_tonalidade.persisted? %>
    <%= link_to "Cancelar", m_tonalidades_path, class: "secondary-button" unless m_tonalidade.persisted? %>
  </div>
<% end %>
