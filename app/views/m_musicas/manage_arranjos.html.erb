<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Arranjos</p>
      <h1><%= @m_musica.descricao %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Novo arranjo", new_m_arranjo_path(m_musica_id: @m_musica.id, from_musica_management: 1), class: "primary-button" %>
      <%= authorized_link_to "Ver música", m_musica_path(@m_musica), class: "secondary-button" %>
      <%= link_to "Voltar", m_musicas_path, class: "secondary-button" %>
    </div>
  </div>

  <div class="show-stack">
    <div class="show-hero">
      <section class="panel-card show-summary">
        <p class="eyebrow">Música</p>
        <h2 class="show-summary__title"><%= @m_musica.descricao %></h2>
      </section>

      <section class="panel-card show-section">
        <div class="panel-card__header">
          <div>
            <p class="eyebrow">Resumo</p>
            <h3>Base musical</h3>
          </div>
        </div>
        <div class="show-stats">
          <div class="show-stat">
            <span class="show-stat__label">Artista</span>
            <span class="show-stat__value"><%= @m_musica.m_artista %></span>
          </div>
          <div class="show-stat">
            <span class="show-stat__label">Compositor</span>
            <span class="show-stat__value"><%= @m_musica.m_compositor %></span>
          </div>
          <div class="show-stat">
            <span class="show-stat__label">Arranjos</span>
            <span class="show-stat__value"><%= @m_arranjos.count %></span>
          </div>
        </div>
      </section>
    </div>

    <section class="panel-card show-section">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Lista</p>
          <h3>Arranjos desta música</h3>
        </div>
        <span class="show-section__count"><%= @m_arranjos.count %></span>
      </div>
      <% if @m_arranjos.any? %>
        <div class="related-grid">
          <% @m_arranjos.each do |arranjo| %>
            <article class="related-card related-card--stack">
              <span class="related-card__label"><%= arranjo.m_tonalidade %></span>
              <%= link_to(arranjo.descricao.presence || "Arranjo ##{arranjo.id}", m_arranjo_path(arranjo), class: "related-card__value related-card__value--link") %>
              <span class="related-card__meta"><%= [arranjo.m_tipo_arranjo, arranjo.m_arranjador, pluralize(arranjo.g_instrumentos_naipes.count, "instrumento")].compact.join(" • ") %></span>

              <section class="attachment-section">
                <span class="attachment-section__title">Arquivos do Arranjo</span>
                <% if arranjo.audio.attached? %>
                  <div class="attachment-stack">
                    <% arranjo.audio.each do |arquivo| %>
                      <%= render "shared/attachment_media", arquivo: arquivo %>
                    <% end %>
                  </div>
                <% else %>
                  <div class="empty-card">Sem arquivo anexado.</div>
                <% end %>
              </section>

              <% if arranjo.m_arranjos_instrumentos_naipes.any? %>
                <section class="attachment-section">
                  <span class="attachment-section__title">Instrumentos do Arranjo</span>
                  <div class="attachment-list">
                  <% arranjo.m_arranjos_instrumentos_naipes.each do |instrumento_arranjo| %>
                    <div class="attachment-row">
                      <div class="attachment-row__main">
                        <span class="attachment-row__label"><%= instrumento_arranjo.g_instrumento_naipe %></span>
                        <% if instrumento_arranjo.arquivo.attached? %>
                          <div class="attachment-stack">
                            <% instrumento_arranjo.arquivo.each do |arquivo| %>
                              <%= render "shared/attachment_media", arquivo: arquivo %>
                            <% end %>
                          </div>
                        <% else %>
                          <span class="attachment-row__empty">Sem anexo</span>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                  </div>
                </section>
              <% else %>
                <div class="empty-card">Nenhum instrumento vinculado ainda.</div>
              <% end %>

              <div class="page-header__actions">
                <%= authorized_link_to "Arquivos", manage_files_m_arranjo_path(arranjo, return_to: manage_arranjos_m_musica_path(@m_musica)), class: "secondary-button" %>
                <%= authorized_link_to "Editar arranjo", edit_m_arranjo_path(arranjo, from_musica_management: 1), class: "secondary-button" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Nenhum arranjo cadastrado para esta música ainda.</div>
      <% end %>
    </section>
  </div>
</div>
