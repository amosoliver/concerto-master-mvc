<div class="page-shell" data-controller="filters view-toggle" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(MMusica) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <%= ui_icon(:search, size: 16, classes: "search-input__icon") %><span>Filtros</span>
      </button>
      <div class="view-switch view-switch--header">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable"><%= ui_icon(:table, size: 15) %><span>Tabela</span></button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards"><%= ui_icon(:layout_grid, size: 15) %><span>Cards</span></button>
      </div>
      <%= authorized_link_to "Novo #{MMusica.model_name.human}", new_m_musica_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: m_musicas_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= MMusica.human_attribute_name(:descricao) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.search_field :descricao_cont, placeholder: MMusica.human_attribute_name(:descricao), "aria-label": MMusica.human_attribute_name(:descricao), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MMusica.human_attribute_name(:m_compositor_id) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.select :m_compositor_id_eq, options_from_collection_for_select(MCompositor.all, :id, :to_s, @q&.send(:m_compositor_id_eq)), { include_blank: true }, "aria-label": MMusica.human_attribute_name(:m_compositor_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MMusica.human_attribute_name(:m_artista_id) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.select :m_artista_id_eq, options_from_collection_for_select(MArtista.all, :id, :to_s, @q&.send(:m_artista_id_eq)), { include_blank: true }, "aria-label": MMusica.human_attribute_name(:m_artista_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", m_musicas_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card panel-card--fill">

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= MMusica.human_attribute_name(:descricao) %></th>
            <th scope="col"><%= MMusica.human_attribute_name(:m_compositor_id) %></th>
            <th scope="col"><%= MMusica.human_attribute_name(:m_artista_id) %></th>
            <th scope="col" class="table-actions-col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @m_musicas.each do |m_musica| %>
            <tr>
              <td><%= m_musica.descricao %></td>
              <td><%= m_musica.m_compositor %></td>
              <td><%= m_musica.m_artista %></td>
              <td class="table-actions-cell">
                <%= render "shared/actions_menu", show_path: m_musica_path(m_musica), edit_path: edit_m_musica_path(m_musica), delete_path: m_musica_path(m_musica), config_path: manage_arranjos_m_musica_path(m_musica), config_label: "Arranjos" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid card-grid--compact" data-view-toggle-target="cards" hidden>
      <% @m_musicas.each do |m_musica| %>
        <article class="record-card record-card--compact">
          <div class="record-card__body">
            <div class="record-card__header">
              <h3 class="record-card__title"><%= m_musica.descricao %></h3>
            </div>
            <div class="record-card__attrs">
              <div class="record-card__attr">
                <span class="record-card__attr-icon"><%= ui_icon(:user, size: 16) %></span>
                <span class="record-card__attr-text">
                  <span class="detail-label"><%= MMusica.human_attribute_name(:m_compositor_id) %></span>
                  <span class="detail-value"><%= m_musica.m_compositor %></span>
                </span>
              </div>
              <div class="record-card__attr">
                <span class="record-card__attr-icon"><%= ui_icon(:music, size: 16) %></span>
                <span class="record-card__attr-text">
                  <span class="detail-label"><%= MMusica.human_attribute_name(:m_artista_id) %></span>
                  <span class="detail-value"><%= m_musica.m_artista %></span>
                </span>
              </div>
            </div>
          </div>
          <%= render "shared/card_actions", show_path: m_musica_path(m_musica), edit_path: edit_m_musica_path(m_musica), delete_path: m_musica_path(m_musica), config_path: manage_arranjos_m_musica_path(m_musica), config_label: "Arranjos" %>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
