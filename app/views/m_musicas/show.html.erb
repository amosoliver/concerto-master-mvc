<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MMusica.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_m_musica_path(@m_musica), class: "primary-button" %>
      <%= link_to "Voltar", m_musicas_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= MMusica.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= MMusica.human_attribute_name(:descricao) %></span>
        <span class="detail-value"><%= @m_musica.descricao %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= MMusica.human_attribute_name(:m_compositor_id) %></span>
        <span class="detail-value"><%= @m_musica.m_compositor %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= MMusica.human_attribute_name(:m_artista_id) %></span>
        <span class="detail-value"><%= @m_musica.m_artista %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@m_musica.created_at) %></span>
      <span>Atualizado em <%= l(@m_musica.updated_at) %></span>
    </div>
  </section>
</div>
