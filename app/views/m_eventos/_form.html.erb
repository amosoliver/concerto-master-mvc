<%= form_with(model: m_evento, local: true, class: "panel-card form-card", data: {
  controller: "select entidade-form evento-repertorio",
  entidade_form_estado_label_value: current_context_entidade&.g_estado&.to_s,
  entidade_form_municipio_label_value: current_context_entidade&.g_municipio&.to_s
}) do |form| %>
  <%= hidden_field_tag :step, current_step %>

  <%= render "shared/form_errors", record: m_evento %>

  <div class="steps-nav">
    <% MEventosController::STEPS.each_with_index do |step, index| %>
      <%= link_to step_path_for(step), class: "steps-nav__item #{'is-active' if current_step == step}" do %>
        <%= "#{index + 1}. #{step.titleize}" %>
      <% end %>
    <% end %>
  </div>

  <% if current_step == "dados" %>
    <div class="panel-card panel-card--embedded">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Etapa 1</p>
          <h3>Dados principais do evento</h3>
        </div>
      </div>

      <div class="form-grid">
        <div class="field-group">
          <%= form.label :descricao %>
          <%= form.text_field :descricao, class: "form-control", data: { controller: "uppercase" } %>
        </div>
        <div class="field-group">
          <%= form.label :g_predio_id %>
          <%= form.collection_select :g_predio_id, @g_predios, :id, :to_s, { include_blank: "Selecione um prédio..." }, class: "form-control" %>
        </div>
        <div class="field-group">
          <%= form.label :data_inicio %>
          <%= form.datetime_field :data_inicio, class: "form-control" %>
        </div>
        <div class="field-group">
          <%= form.label :data_fim %>
          <%= form.datetime_field :data_fim, class: "form-control" %>
        </div>
      </div>
    </div>

    <details class="field-toggle" <%= "open" if m_evento.g_predio.blank? || m_evento.novo_g_predio_nome_fantasia.present? %>>
      <summary class="secondary-button">Cadastrar prédio no fluxo do evento</summary>
      <div class="field-toggle__content">
        <div class="form-grid">
          <div class="field-group">
            <%= form.label :novo_g_predio_nome_fantasia, "Nome do prédio" %>
            <%= form.text_field :novo_g_predio_nome_fantasia, class: "form-control", data: { controller: "uppercase" } %>
          </div>
          <div class="field-group">
            <%= form.label :novo_g_predio_cep, "CEP" %>
            <%= form.text_field :novo_g_predio_cep, class: "form-control", inputmode: "numeric", maxlength: 9, data: { controller: "mask", mask_pattern_value: "cep", entidade_form_target: "cep", action: "input->entidade-form#addressChanged" } %>
          </div>
          <div class="field-group">
            <%= form.label :novo_g_predio_logradouro, "Logradouro" %>
            <%= form.text_field :novo_g_predio_logradouro, class: "form-control", data: { controller: "uppercase", entidade_form_target: "logradouro", action: "input->entidade-form#addressChanged" } %>
          </div>
          <div class="field-group">
            <%= form.label :novo_g_predio_bairro, "Bairro" %>
            <%= form.text_field :novo_g_predio_bairro, class: "form-control", data: { controller: "uppercase", entidade_form_target: "bairro", action: "input->entidade-form#addressChanged" } %>
          </div>
          <%= form.hidden_field :novo_g_predio_latitude, data: { entidade_form_target: "latitude" } %>
          <%= form.hidden_field :novo_g_predio_longitude, data: { entidade_form_target: "longitude" } %>
          <div class="field-group field-group--full">
            <div class="map-card">
              <div class="map-card__header">
                <div>
                  <h4>Mapa do prédio do evento</h4>
                  <p data-entidade-form-target="mapStatus">
                    <% if m_evento.novo_g_predio_latitude.present? && m_evento.novo_g_predio_longitude.present? %>
                      Endereço localizado com sucesso.
                    <% else %>
                      Preencha o endereço do prédio para marcar a localização automaticamente.
                    <% end %>
                  </p>
                </div>
                <a href="<%= m_evento.novo_g_predio_latitude.present? && m_evento.novo_g_predio_longitude.present? ? "https://www.openstreetmap.org/?mlat=#{m_evento.novo_g_predio_latitude}&mlon=#{m_evento.novo_g_predio_longitude}#map=16/#{m_evento.novo_g_predio_latitude}/#{m_evento.novo_g_predio_longitude}" : "#" %>" target="_blank" rel="noopener" class="secondary-button" data-entidade-form-target="mapLink">Abrir mapa</a>
              </div>
              <iframe
                title="Mapa do prédio do evento"
                class="map-card__frame"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                src="<%= if m_evento.novo_g_predio_latitude.present? && m_evento.novo_g_predio_longitude.present?
                  lat = m_evento.novo_g_predio_latitude.to_f
                  lng = m_evento.novo_g_predio_longitude.to_f
                  delta = 0.01
                  bbox = [lng - delta, lat - delta, lng + delta, lat + delta].join('%2C')
                  marker = "#{lat}%2C#{lng}"
                  "https://www.openstreetmap.org/export/embed.html?bbox=#{bbox}&layer=mapnik&marker=#{marker}"
                end %>"
                data-entidade-form-target="mapFrame"></iframe>
            </div>
          </div>
        </div>
      </div>
    </details>
  <% elsif current_step == "repertorio" %>
    <div class="panel-card panel-card--embedded">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Etapa 2</p>
          <h3>Músicas e arranjos do evento</h3>
        </div>
      </div>

      <% if @m_musicas.any? %>
        <div class="wizard-repertorio">
          <% @m_musicas.each_with_index do |musica, index| %>
            <% selected_entry = @selected_repertorio[musica.id] || {} %>
            <% arranjos = Array(@arranjos_por_musica[musica.id]) %>
            <% checked = selected_entry.present? %>
            <% item_key = "evento-musica-#{index}" %>
            <article class="wizard-repertorio__item">
              <div class="wizard-repertorio__header">
                <label class="selection-item">
                  <%= check_box_tag "m_evento[repertorio][#{index}][selecionada]",
                                    "1",
                                    checked,
                                    data: { action: "change->evento-repertorio#toggleMusica", evento_repertorio_target: "musicaCheckbox", item_key: item_key } %>
                  <span><strong><%= musica.descricao %></strong></span>
                </label>
                <%= hidden_field_tag "m_evento[repertorio][#{index}][m_musica_id]", musica.id %>
              </div>

              <div class="wizard-repertorio__meta">
                <span><%= musica.m_artista %></span>
                <span><%= musica.m_compositor.presence || "Sem compositor informado" %></span>
                <span><%= pluralize(arranjos.count, "arranjo") %></span>
              </div>

              <div class="field-group">
                <label>Arranjo do evento</label>
                <%= select_tag "m_evento[repertorio][#{index}][m_arranjo_id]",
                               options_from_collection_for_select(arranjos, :id, :to_s, selected_entry[:m_arranjo_id]),
                               include_blank: arranjos.any? ? "Definir depois" : "Nenhum arranjo cadastrado",
                               class: "form-control",
                               disabled: arranjos.empty? %>
              </div>

              <div class="field-group">
                <label>Grupos que executam esta música</label>
                <% if @m_grupos.any? %>
                  <div class="selection-group__items" data-evento-repertorio-target="grupoContainer" data-item-key="<%= item_key %>">
                    <% selected_group_ids = Array(selected_entry[:m_grupo_ids]).map(&:to_i) %>
                    <% @m_grupos.each do |grupo| %>
                      <label class="selection-item">
                        <%= check_box_tag "m_evento[repertorio][#{index}][m_grupo_ids][]", grupo.id, selected_group_ids.include?(grupo.id) %>
                        <span><%= grupo.descricao %></span>
                      </label>
                    <% end %>
                  </div>
                <% else %>
                  <div class="empty-card">Nenhum grupo cadastrado na entidade atual.</div>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Nenhuma música disponível na entidade atual para compor o repertório.</div>
      <% end %>
    </div>
  <% else %>
    <div class="panel-card panel-card--embedded">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Etapa 3</p>
          <h3>Revisão antes de salvar</h3>
        </div>
      </div>

      <div class="detail-grid">
        <div class="detail-tile">
          <span class="detail-label">Evento</span>
          <span class="detail-value"><%= m_evento.descricao.presence || "Preencha a descrição no passo 1" %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label">Prédio</span>
          <span class="detail-value"><%= m_evento.g_predio || m_evento.novo_g_predio_nome_fantasia.presence || "Selecione ou cadastre um prédio" %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label">Período</span>
          <span class="detail-value">
            <%= format_datetime_range(m_evento.data_inicio, m_evento.data_fim) %>
          </span>
        </div>
        <div class="detail-tile">
          <span class="detail-label">Repertório</span>
          <span class="detail-value"><%= pluralize(@selected_repertorio.size, "música") %> selecionada(s) até agora</span>
        </div>
      </div>
    </div>
  <% end %>

  <div class="form-actions">
    <% unless first_step? %>
      <%= button_tag "Voltar", name: :navigation, value: "previous", class: "secondary-button" %>
    <% end %>
    <%= form.submit(last_step? ? (m_evento.persisted? ? "Atualizar evento" : "Criar evento") : "Próximo", class: "primary-button") %>
    <%= link_to "Cancelar", m_evento.persisted? ? m_evento_path(m_evento) : m_eventos_path, class: "secondary-button" %>
  </div>
<% end %>
