<%= form_with(model: m_evento, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: m_evento %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control", data: { controller: "uppercase" } %>
    </div>
    <div class="field-group">
      <%= form.label :data_inicio %>
      <%= form.datetime_field :data_inicio, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :data_fim %>
      <%= form.datetime_field :data_fim, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :g_predio_id %>
      <%= form.collection_select :g_predio_id, tenant_predio_scope, :id, :to_s, { include_blank: "Selecione um prédio..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", m_evento_path(@m_evento), class: "secondary-button" if m_evento.persisted? %>
    <%= link_to "Cancelar", m_eventos_path, class: "secondary-button" unless m_evento.persisted? %>
  </div>
<% end %>
