<div class="page-shell" data-controller="filters" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(MEvento) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <span aria-hidden="true">🔎</span> Filtros
      </button>
      <%= authorized_link_to "Novo #{MEvento.model_name.human}", new_m_evento_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: m_eventos_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= MEvento.human_attribute_name(:descricao) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :descricao_cont, placeholder: MEvento.human_attribute_name(:descricao), "aria-label": MEvento.human_attribute_name(:descricao), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MEvento.human_attribute_name(:data_inicio) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :data_inicio_cont, placeholder: MEvento.human_attribute_name(:data_inicio), "aria-label": MEvento.human_attribute_name(:data_inicio), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MEvento.human_attribute_name(:data_fim) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :data_fim_cont, placeholder: MEvento.human_attribute_name(:data_fim), "aria-label": MEvento.human_attribute_name(:data_fim), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MEvento.human_attribute_name(:g_predio_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_predio_id_eq, options_from_collection_for_select(tenant_predio_scope, :id, :to_s, @q&.send(:g_predio_id_eq)), { include_blank: true }, "aria-label": MEvento.human_attribute_name(:g_predio_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", m_eventos_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@m_eventos.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= MEvento.human_attribute_name(:descricao) %></th>
            <th scope="col"><%= MEvento.human_attribute_name(:data_inicio) %></th>
            <th scope="col"><%= MEvento.human_attribute_name(:data_fim) %></th>
            <th scope="col"><%= MEvento.human_attribute_name(:g_predio_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @m_eventos.each do |m_evento| %>
            <tr>
              <td><%= m_evento.descricao %></td>
              <td><%= m_evento.data_inicio %></td>
              <td><%= m_evento.data_fim %></td>
              <td><%= m_evento.g_predio %></td>
              <td>
                <%= render "shared/actions_menu", show_path: m_evento_path(m_evento), edit_path: edit_m_evento_path(m_evento), delete_path: m_evento_path(m_evento), config_path: manage_m_evento_path(m_evento) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @m_eventos.each do |m_evento| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= MEvento.human_attribute_name(:descricao) %></span>
            <span class="detail-value"><%= m_evento.descricao %></span>
            <span class="detail-label"><%= MEvento.human_attribute_name(:data_inicio) %></span>
            <span class="detail-value"><%= m_evento.data_inicio %></span>
            <span class="detail-label"><%= MEvento.human_attribute_name(:data_fim) %></span>
            <span class="detail-value"><%= m_evento.data_fim %></span>
            <span class="detail-label"><%= MEvento.human_attribute_name(:g_predio_id) %></span>
            <span class="detail-value"><%= m_evento.g_predio %></span>
            <span class="detail-label">Repertório</span>
            <span class="detail-value"><%= pluralize(m_evento.repertorio_count, "música") %></span>
          </div>
          <% if m_evento.m_eventos_musicas.any? %>
            <div class="record-card__summary">
              <% m_evento.m_eventos_musicas.first(3).each do |evento_musica| %>
                <span class="tag-cloud__item"><%= evento_musica.m_musica.descricao %></span>
              <% end %>
            </div>
          <% end %>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: m_evento_path(m_evento), edit_path: edit_m_evento_path(m_evento), delete_path: m_evento_path(m_evento), config_path: manage_m_evento_path(m_evento) %>
          </div>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
