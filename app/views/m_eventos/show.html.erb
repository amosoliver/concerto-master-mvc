<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MEvento.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Gerenciar", manage_m_evento_path(@m_evento), class: "primary-button" %>
      <%= authorized_link_to "Editar", edit_m_evento_path(@m_evento), class: "secondary-button" %>
      <%= link_to "Voltar", m_eventos_path, class: "secondary-button" %>
    </div>
  </div>

  <div class="show-stack">
    <div class="show-hero">
      <section class="panel-card show-summary">
        <p class="eyebrow">Evento</p>
        <h2 class="show-summary__title"><%= @m_evento.descricao %></h2>
        <p class="show-summary__text show-summary__text--highlight">Início em <%= format_datetime(@m_evento.data_inicio) %></p>
      </section>

      <% predio = @m_evento.g_predio %>
      <section class="panel-card show-section show-location">
        <div class="panel-card__header">
          <div>
            <p class="eyebrow">Local</p>
            <h3><%= predio %></h3>
          </div>
          <% if openstreetmap_url(predio).present? %>
            <%= link_to "Abrir mapa", openstreetmap_url(predio), target: "_blank", rel: "noopener", class: "secondary-button" %>
          <% end %>
        </div>
        <div class="show-location__grid">
          <div class="show-location__content">
            <p class="show-location__address"><%= predio_location_line(predio).presence || "Endereço indisponível" %></p>
          </div>
          <% if openstreetmap_embed_url(predio).present? %>
            <iframe
              title="Mapa do local do evento"
              class="show-location__map"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="<%= openstreetmap_embed_url(predio) %>"></iframe>
          <% end %>
        </div>
      </section>
    </div>

    <section class="panel-card show-section show-section--full-width">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Repertório</p>
          <h3>Músicas, arranjos e arquivos do seu naipe</h3>
        </div>
      </div>
      <% if @evento_repertorio.any? %>
        <div class="evento-showcase">
          <% @evento_repertorio.each do |evento_musica| %>
            <%= render "shared/music_track_card", evento_musica: evento_musica %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Nenhuma música foi vinculada a este evento.</div>
      <% end %>
    </section>
  </div>
</div>
