<div class="page-shell" data-controller="filters" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(MArranjo) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <span aria-hidden="true">🔎</span> Filtros
      </button>
      <%= authorized_link_to "Novo #{MArranjo.model_name.human}", new_m_arranjo_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: m_arranjos_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= MArranjo.human_attribute_name(:m_musica_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :m_musica_id_eq, options_from_collection_for_select(tenant_musica_scope, :id, :to_s, @q&.send(:m_musica_id_eq)), { include_blank: true }, "aria-label": MArranjo.human_attribute_name(:m_musica_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MArranjo.human_attribute_name(:m_arranjador_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :m_arranjador_id_eq, options_from_collection_for_select(MArranjador.all, :id, :to_s, @q&.send(:m_arranjador_id_eq)), { include_blank: true }, "aria-label": MArranjo.human_attribute_name(:m_arranjador_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MArranjo.human_attribute_name(:m_tonalidade_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :m_tonalidade_id_eq, options_from_collection_for_select(MTonalidade.all, :id, :to_s, @q&.send(:m_tonalidade_id_eq)), { include_blank: true }, "aria-label": MArranjo.human_attribute_name(:m_tonalidade_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", m_arranjos_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@m_arranjos.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= MArranjo.human_attribute_name(:m_musica_id) %></th>
            <th scope="col"><%= MArranjo.human_attribute_name(:m_arranjador_id) %></th>
            <th scope="col"><%= MArranjo.human_attribute_name(:m_tonalidade_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @m_arranjos.each do |m_arranjo| %>
            <tr>
              <td><%= m_arranjo.m_musica %></td>
              <td><%= m_arranjo.m_arranjador %></td>
              <td><%= m_arranjo.m_tonalidade %></td>
              <td>
                <%= render "shared/actions_menu", show_path: m_arranjo_path(m_arranjo), edit_path: edit_m_arranjo_path(m_arranjo), delete_path: m_arranjo_path(m_arranjo) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @m_arranjos.each do |m_arranjo| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= MArranjo.human_attribute_name(:m_musica_id) %></span>
            <span class="detail-value"><%= m_arranjo.m_musica %></span>
            <span class="detail-label"><%= MArranjo.human_attribute_name(:m_arranjador_id) %></span>
            <span class="detail-value"><%= m_arranjo.m_arranjador %></span>
            <span class="detail-label"><%= MArranjo.human_attribute_name(:m_tonalidade_id) %></span>
            <span class="detail-value"><%= m_arranjo.m_tonalidade %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: m_arranjo_path(m_arranjo), edit_path: edit_m_arranjo_path(m_arranjo), delete_path: m_arranjo_path(m_arranjo) %>
          </div>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
