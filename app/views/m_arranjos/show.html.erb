<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MArranjo.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_m_arranjo_path(@m_arranjo), class: "primary-button" %>
      <%= link_to "Voltar", m_arranjos_path, class: "secondary-button" %>
    </div>
  </div>

  <div class="show-stack">
    <div class="show-hero">
      <section class="panel-card show-summary">
        <p class="eyebrow">Arranjo</p>
        <h2 class="show-summary__title"><%= @m_arranjo.descricao.presence || "#{@m_arranjo.m_musica} - #{@m_arranjo.m_arranjador}" %></h2>
        <p class="show-summary__text"><%= [@m_arranjo.m_tipo_arranjo, @m_arranjo.m_arranjador, @m_arranjo.m_tonalidade].compact.join(" • ") %></p>
      </section>

      <section class="panel-card show-section">
        <div class="panel-card__header">
          <div>
            <p class="eyebrow">Resumo</p>
            <h3>Instrumentação</h3>
          </div>
        </div>
        <div class="show-stats">
          <div class="show-stat">
            <span class="show-stat__label">Instrumentos</span>
            <span class="show-stat__value"><%= @m_arranjo.g_instrumentos_naipes.count %></span>
          </div>
          <div class="show-stat">
            <span class="show-stat__label">Música</span>
            <span class="show-stat__value">#<%= @m_arranjo.m_musica_id %></span>
          </div>
        </div>
      </section>
    </div>

    <section class="panel-card detail-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Dados</p>
          <h3>Dados principais</h3>
        </div>
      </div>

      <div class="detail-grid">
        <div class="detail-tile">
          <span class="detail-label"><%= MArranjo.human_attribute_name(:descricao) %></span>
          <span class="detail-value"><%= @m_arranjo.descricao.presence || "-" %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MArranjo.human_attribute_name(:m_musica_id) %></span>
          <span class="detail-value"><%= @m_arranjo.m_musica %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MArranjo.human_attribute_name(:m_tipo_arranjo_id) %></span>
          <span class="detail-value"><%= @m_arranjo.m_tipo_arranjo %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MArranjo.human_attribute_name(:m_arranjador_id) %></span>
          <span class="detail-value"><%= @m_arranjo.m_arranjador %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MArranjo.human_attribute_name(:m_tonalidade_id) %></span>
          <span class="detail-value"><%= @m_arranjo.m_tonalidade %></span>
        </div>
      </div>

      <div class="detail-meta">
        <span>Criado em <%= format_timestamp(@m_arranjo.created_at) %></span>
        <span>Atualizado em <%= format_timestamp(@m_arranjo.updated_at) %></span>
      </div>
    </section>

    <section class="panel-card show-section">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Instrumentos</p>
          <h3>Arquivos do seu instrumento ou naipe</h3>
        </div>
        <% user_relations = instrument_relations_for_current_user(@m_arranjo) %>
        <span class="show-section__count"><%= user_relations.count %></span>
      </div>
      <% if !current_user_has_instrument_assignments? %>
        <div class="empty-card">Seu usuário não possui instrumento/naipe associado nesta entidade.</div>
      <% elsif user_relations.any? %>
        <div class="related-grid">
          <% user_relations.each do |instrumento_arranjo| %>
            <article class="related-card">
              <span class="related-card__label">Instrumento</span>
              <span class="related-card__value"><%= instrumento_arranjo.g_instrumento_naipe.to_s %></span>
              <% if instrumento_arranjo.arquivo.attached? %>
                <div class="attachment-stack">
                  <% instrumento_arranjo.arquivo.each do |arquivo| %>
                    <%= render "shared/attachment_media", arquivo: arquivo %>
                  <% end %>
                </div>
              <% else %>
                <span class="related-card__meta">Sem anexo</span>
              <% end %>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Este arranjo não possui arquivo específico para o instrumento/naipe associado ao seu usuário.</div>
      <% end %>
    </section>
  </div>
</div>
