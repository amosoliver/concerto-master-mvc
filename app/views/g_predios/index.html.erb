<div class="page-shell" data-controller="filters view-toggle" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(GPredio) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <%= ui_icon(:search, size: 16, classes: "search-input__icon") %><span>Filtros</span>
      </button>
      <div class="view-switch view-switch--header">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable"><%= ui_icon(:table, size: 15) %><span>Tabela</span></button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards"><%= ui_icon(:layout_grid, size: 15) %><span>Cards</span></button>
      </div>
      <%= authorized_link_to "Novo #{GPredio.model_name.human}", new_g_predio_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: g_predios_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= GPredio.human_attribute_name(:nome_fantasia) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.search_field :nome_fantasia_cont, placeholder: GPredio.human_attribute_name(:nome_fantasia), "aria-label": GPredio.human_attribute_name(:nome_fantasia), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPredio.human_attribute_name(:cep) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.search_field :cep_cont, placeholder: GPredio.human_attribute_name(:cep), "aria-label": GPredio.human_attribute_name(:cep), class: "search-input__field", inputmode: "numeric", maxlength: 9, data: { controller: "mask", mask_pattern_value: "cep" } %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPredio.human_attribute_name(:logradouro) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.search_field :logradouro_cont, placeholder: GPredio.human_attribute_name(:logradouro), "aria-label": GPredio.human_attribute_name(:logradouro), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPredio.human_attribute_name(:bairro) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.search_field :bairro_cont, placeholder: GPredio.human_attribute_name(:bairro), "aria-label": GPredio.human_attribute_name(:bairro), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPredio.human_attribute_name(:g_entidade_id) %></label>
          <div class="search-input">
            <%= ui_icon(:search, size: 16, classes: "search-input__icon") %>
            <%= f.select :g_entidade_id_eq, options_from_collection_for_select(tenant_entity_scope, :id, :to_s, @q&.send(:g_entidade_id_eq)), { include_blank: true }, "aria-label": GPredio.human_attribute_name(:g_entidade_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", g_predios_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card panel-card--fill">

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= GPredio.human_attribute_name(:nome_fantasia) %></th>
            <th scope="col"><%= GPredio.human_attribute_name(:cep) %></th>
            <th scope="col"><%= GPredio.human_attribute_name(:logradouro) %></th>
            <th scope="col"><%= GPredio.human_attribute_name(:bairro) %></th>
            <th scope="col"><%= GPredio.human_attribute_name(:g_entidade_id) %></th>
            <th scope="col" class="table-actions-col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @g_predios.each do |g_predio| %>
            <tr>
              <td><%= g_predio.nome_fantasia %></td>
              <td><%= format_cep(g_predio.cep) %></td>
              <td><%= g_predio.logradouro %></td>
              <td><%= g_predio.bairro %></td>
              <td><%= g_predio.g_entidade %></td>
              <td class="table-actions-cell">
                <%= render "shared/actions_menu", show_path: g_predio_path(g_predio), edit_path: edit_g_predio_path(g_predio), delete_path: g_predio_path(g_predio) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @g_predios.each do |g_predio| %>
        <article class="record-card">
          <div class="record-card__body">
            <div class="record-card__header">
              <h3 class="record-card__title"><%= g_predio.nome_fantasia %></h3>
            </div>
            <div class="record-card__attrs">
              <div class="record-card__attr">
                <span class="record-card__attr-icon"><%= ui_icon(:key, size: 16) %></span>
                <span class="record-card__attr-text">
                  <span class="detail-label"><%= GPredio.human_attribute_name(:cep) %></span>
                  <span class="detail-value"><%= format_cep(g_predio.cep) %></span>
                </span>
              </div>
              <div class="record-card__attr">
                <span class="record-card__attr-icon"><%= ui_icon(:map, size: 16) %></span>
                <span class="record-card__attr-text">
                  <span class="detail-label"><%= GPredio.human_attribute_name(:logradouro) %></span>
                  <span class="detail-value"><%= g_predio.logradouro %></span>
                </span>
              </div>
              <div class="record-card__attr">
                <span class="record-card__attr-icon"><%= ui_icon(:map_pin, size: 16) %></span>
                <span class="record-card__attr-text">
                  <span class="detail-label"><%= GPredio.human_attribute_name(:bairro) %></span>
                  <span class="detail-value"><%= g_predio.bairro %></span>
                </span>
              </div>
              <div class="record-card__attr">
                <span class="record-card__attr-icon"><%= ui_icon(:building_bank, size: 16) %></span>
                <span class="record-card__attr-text">
                  <span class="detail-label"><%= GPredio.human_attribute_name(:g_entidade_id) %></span>
                  <span class="detail-value"><%= g_predio.g_entidade %></span>
                </span>
              </div>
            </div>
          </div>
          <%= render "shared/card_actions", show_path: g_predio_path(g_predio), edit_path: edit_g_predio_path(g_predio), delete_path: g_predio_path(g_predio) %>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
