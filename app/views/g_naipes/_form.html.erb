<%= form_with(model: g_naipe, local: true, class: "panel-card form-card") do |form| %>
  <%= render "shared/form_errors", record: g_naipe %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", g_naipe_path(@g_naipe), class: "secondary-button" if g_naipe.persisted? %>
    <%= link_to "Cancelar", g_naipes_path, class: "secondary-button" unless g_naipe.persisted? %>
  </div>
<% end %>
