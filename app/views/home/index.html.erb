<section class="hero-card">
  <div>
    <p class="eyebrow">Painel da entidade</p>
    <h2><%= current_context_entidade || "Agenda musical" %></h2>
  </div>
  <div class="page-header__actions">
    <div class="view-switch">
      <%= link_to "Agenda", root_path, class: "view-switch__btn is-active" %>
      <%= link_to "Pessoal", dashboard_grupos_path, class: "view-switch__btn" %>
    </div>
    <%= authorized_link_to "Novo evento", new_m_evento_path, class: "primary-button" %>
  </div>
</section>

<% unless current_user_has_instrument_assignments? %>
  <div class="empty-card">Seu usuário não possui instrumento/naipe associado nesta entidade. Os arquivos específicos por instrumento não serão exibidos até esse vínculo ser definido.</div>
<% end %>

<div class="dashboard-layout">
  <%= render "shared/entity_calendar", snapshot: @dashboard_snapshot, base_path: root_path, base_params: request.query_parameters.except("month", "view", "date").symbolize_keys %>

  <section class="panel-card dashboard-sidecard">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Próximos compromissos</p>
        <h3>Agenda imediata</h3>
      </div>
    </div>
    <% if @dashboard_snapshot[:upcoming_entries].any? %>
      <% next_entry = @dashboard_snapshot[:next_event] %>
      <% remaining_entries = @dashboard_snapshot[:upcoming_entries].drop(1) %>

      <% if next_entry.present? %>
        <%= link_to calendar_entry_path(next_entry), class: "next-event-card #{calendar_entry_css_class(next_entry)}" do %>
          <div class="next-event-card__eyebrow">
            <span class="pill">Próximo</span>
            <span><%= calendar_entry_type_label(next_entry) %></span>
          </div>
          <strong class="next-event-card__title"><%= next_entry[:title] %></strong>
          <div class="next-event-card__meta">
            <span><%= format_datetime(next_entry[:starts_at]) %></span>
            <span><%= next_entry[:location] %></span>
          </div>
        <% end %>
      <% end %>

      <% if remaining_entries.any? %>
        <div class="dashboard-sidecard__subheader">
          <p>Na sequência</p>
        </div>

        <ul class="event-list">
          <% remaining_entries.each do |entry| %>
            <li>
              <%= link_to calendar_entry_path(entry), class: "event-list__link" do %>
                <span>
                  <strong><%= entry[:title] %></strong><br>
                  <small><%= calendar_entry_type_label(entry) %> • <%= entry[:location] %></small>
                </span>
                <strong><%= format_datetime(entry[:starts_at]) %></strong>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    <% else %>
      <div class="empty-card">Nenhum compromisso futuro cadastrado para esta entidade.</div>
    <% end %>
  </section>
</div>
