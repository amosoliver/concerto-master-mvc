<section class="hero-card">
  <div>
    <p class="eyebrow">Painel da entidade</p>
    <h2><%= current_context_entidade || "Agenda musical" %></h2>
    <p>O painel principal mostra somente a agenda da entidade, com o calendário do mês e os próximos compromissos logo ao lado.</p>
  </div>
  <div class="page-header__actions">
    <div class="view-switch">
      <%= link_to "Agenda", root_path, class: "view-switch__btn is-active" %>
      <%= link_to "Pessoal", dashboard_grupos_path, class: "view-switch__btn" %>
    </div>
    <%= authorized_link_to "Novo evento", new_m_evento_path, class: "primary-button" %>
  </div>
</section>

<div class="dashboard-layout">
  <%= render "shared/entity_calendar", snapshot: @dashboard_snapshot, base_path: root_path, base_params: request.query_parameters.except("month", "view", "date").symbolize_keys %>

  <section class="panel-card dashboard-sidecard">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Próximos eventos</p>
        <h3>Agenda imediata</h3>
      </div>
    </div>
    <% if @dashboard_snapshot[:upcoming_events].any? %>
      <ul class="event-list">
        <% @dashboard_snapshot[:upcoming_events].each do |evento| %>
          <li>
            <span>
              <strong><%= evento.descricao %></strong><br>
              <small><%= evento.g_predio %></small>
            </span>
            <strong><%= format_datetime(evento.data_inicio) %></strong>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="empty-card">Nenhum evento futuro cadastrado para esta entidade.</div>
    <% end %>
  </section>
</div>
