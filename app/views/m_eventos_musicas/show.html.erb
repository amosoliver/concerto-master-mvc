<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MEventoMusica.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_m_evento_musica_path(@m_evento_musica), class: "primary-button" %>
      <%= link_to "Voltar", m_eventos_musicas_path, class: "secondary-button" %>
    </div>
  </div>

  <div class="show-stack">
    <div class="show-hero">
      <section class="panel-card show-summary">
        <p class="eyebrow">Repertório do evento</p>
        <h2 class="show-summary__title"><%= @m_evento_musica.m_musica %></h2>
        <p class="show-summary__text">Música vinculada ao evento <%= @m_evento_musica.m_evento %> para organização do repertório e ensaios.</p>
      </section>

      <section class="panel-card show-section">
        <div class="panel-card__header">
          <div>
            <p class="eyebrow">Resumo</p>
            <h3>Impacto</h3>
          </div>
        </div>
        <div class="show-stats">
          <div class="show-stat">
            <span class="show-stat__label">Ensaios</span>
            <span class="show-stat__value"><%= @m_evento_musica.m_ensaio_musicas.count %></span>
          </div>
          <div class="show-stat">
            <span class="show-stat__label">Evento</span>
            <span class="show-stat__value"><%= @m_evento_musica.m_evento.data_inicio.present? ? l(@m_evento_musica.m_evento.data_inicio) : "-" %></span>
          </div>
        </div>
      </section>
    </div>

    <section class="panel-card detail-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Informações</p>
          <h3><%= MEventoMusica.model_name.human %></h3>
        </div>
      </div>

      <div class="detail-grid">
        <div class="detail-tile">
          <span class="detail-label"><%= MEventoMusica.human_attribute_name(:m_evento_id) %></span>
          <span class="detail-value"><%= @m_evento_musica.m_evento %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MEventoMusica.human_attribute_name(:m_musica_id) %></span>
          <span class="detail-value"><%= @m_evento_musica.m_musica %></span>
        </div>
      </div>

      <div class="detail-meta">
        <span>Criado em <%= l(@m_evento_musica.created_at) %></span>
        <span>Atualizado em <%= l(@m_evento_musica.updated_at) %></span>
      </div>
    </section>

    <section class="panel-card show-section">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Ensaios</p>
          <h3>Onde esta música foi trabalhada</h3>
        </div>
        <span class="show-section__count"><%= @m_evento_musica.m_ensaio_musicas.count %></span>
      </div>
      <% if @m_evento_musica.m_ensaio_musicas.any? %>
        <div class="related-grid">
          <% @m_evento_musica.m_ensaio_musicas.includes(:m_ensaio).each do |ensaio_musica| %>
            <article class="related-card">
              <span class="related-card__label">Ensaio</span>
              <%= link_to ensaio_musica.m_ensaio, m_ensaio_path(ensaio_musica.m_ensaio), class: "related-card__value related-card__value--link" %>
              <span class="related-card__meta"><%= ensaio_musica.observacao.presence || "Sem observação" %></span>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Esta música ainda não foi relacionada a nenhum ensaio.</div>
      <% end %>
    </section>
  </div>
</div>
