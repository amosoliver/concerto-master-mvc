<%= form_with(model: u_funcao, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: u_funcao %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :u_tipo_funcao_id %>
      <%= form.collection_select :u_tipo_funcao_id, UTipoFuncao.all, :id, :to_s, { include_blank: "Selecione um tipo de função..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", u_funcao_path(@u_funcao), class: "secondary-button" if u_funcao.persisted? %>
    <%= link_to "Cancelar", u_funcoes_path, class: "secondary-button" unless u_funcao.persisted? %>
  </div>
<% end %>
