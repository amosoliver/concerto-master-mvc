<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MArtista.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= link_to "Editar", edit_m_artista_path(@m_artista), class: "primary-button" %>
      <%= link_to "Voltar", m_artistas_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= MArtista.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= MArtista.human_attribute_name(:descricao) %></span>
        <span class="detail-value"><%= @m_artista.descricao %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@m_artista.created_at) %></span>
      <span>Atualizado em <%= l(@m_artista.updated_at) %></span>
    </div>
  </section>
</div>
