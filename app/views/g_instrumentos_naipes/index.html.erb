<div class="page-shell" data-controller="filters" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(GInstrumentoNaipe) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <span aria-hidden="true">🔎</span> Filtros
      </button>
      <%= authorized_link_to "Novo #{GInstrumentoNaipe.model_name.human}", new_g_instrumento_naipe_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: g_instrumentos_naipes_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= GInstrumentoNaipe.human_attribute_name(:g_instrumento_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_instrumento_id_eq, options_from_collection_for_select(GInstrumento.all, :id, :to_s, @q&.send(:g_instrumento_id_eq)), { include_blank: true }, "aria-label": GInstrumentoNaipe.human_attribute_name(:g_instrumento_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GInstrumentoNaipe.human_attribute_name(:g_naipe_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_naipe_id_eq, options_from_collection_for_select(GNaipe.all, :id, :to_s, @q&.send(:g_naipe_id_eq)), { include_blank: true }, "aria-label": GInstrumentoNaipe.human_attribute_name(:g_naipe_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", g_instrumentos_naipes_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@g_instrumentos_naipes.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= GInstrumentoNaipe.human_attribute_name(:g_instrumento_id) %></th>
            <th scope="col"><%= GInstrumentoNaipe.human_attribute_name(:g_naipe_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @g_instrumentos_naipes.each do |g_instrumento_naipe| %>
            <tr>
              <td><%= g_instrumento_naipe.g_instrumento %></td>
              <td><%= g_instrumento_naipe.g_naipe %></td>
              <td>
                <%= render "shared/actions_menu", show_path: g_instrumento_naipe_path(g_instrumento_naipe), edit_path: edit_g_instrumento_naipe_path(g_instrumento_naipe), delete_path: g_instrumento_naipe_path(g_instrumento_naipe) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @g_instrumentos_naipes.each do |g_instrumento_naipe| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= GInstrumentoNaipe.human_attribute_name(:g_instrumento_id) %></span>
            <span class="detail-value"><%= g_instrumento_naipe.g_instrumento %></span>
            <span class="detail-label"><%= GInstrumentoNaipe.human_attribute_name(:g_naipe_id) %></span>
            <span class="detail-value"><%= g_instrumento_naipe.g_naipe %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: g_instrumento_naipe_path(g_instrumento_naipe), edit_path: edit_g_instrumento_naipe_path(g_instrumento_naipe), delete_path: g_instrumento_naipe_path(g_instrumento_naipe) %>
          </div>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
