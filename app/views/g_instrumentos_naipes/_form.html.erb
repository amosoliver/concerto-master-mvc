<%= form_with(model: g_instrumento_naipe, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: g_instrumento_naipe %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :g_instrumento_id %>
      <%= form.collection_select :g_instrumento_id, @g_instrumentos, :id, :to_s, { include_blank: "Selecione um instrumento existente..." }, class: "form-control" %>
      <details class="field-toggle" <%= "open" if g_instrumento_naipe.novo_g_instrumento.present? %>>
        <summary class="secondary-button">Cadastrar novo instrumento</summary>
        <div class="field-toggle__content">
          <small class="field-hint">Se preencher aqui, o sistema cria o instrumento e usa ele neste vinculo.</small>
          <%= form.text_field :novo_g_instrumento, class: "form-control", placeholder: "Digite um novo instrumento", data: { controller: "uppercase" } %>
        </div>
      </details>
    </div>
    <div class="field-group">
      <%= form.label :g_naipe_id %>
      <%= form.collection_select :g_naipe_id, @g_naipes, :id, :to_s, { include_blank: "Selecione um naipe existente..." }, class: "form-control" %>
      <details class="field-toggle" <%= "open" if g_instrumento_naipe.novo_g_naipe.present? %>>
        <summary class="secondary-button">Cadastrar novo naipe</summary>
        <div class="field-toggle__content">
          <small class="field-hint">Se preencher aqui, o sistema cria o naipe e usa ele neste vinculo.</small>
          <%= form.text_field :novo_g_naipe, class: "form-control", placeholder: "Digite um novo naipe", data: { controller: "uppercase" } %>
        </div>
      </details>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", g_instrumento_naipe_path(@g_instrumento_naipe), class: "secondary-button" if g_instrumento_naipe.persisted? %>
    <%= link_to "Cancelar", g_instrumentos_naipes_path, class: "secondary-button" unless g_instrumento_naipe.persisted? %>
  </div>
<% end %>
