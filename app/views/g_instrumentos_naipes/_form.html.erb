<%= form_with(model: g_instrumento_naipe, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <% if g_instrumento_naipe.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= pluralize(g_instrumento_naipe.errors.count, "erro") %> impediram o salvamento:</h2>
      <ul>
        <% g_instrumento_naipe.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :g_instrumento_id %>
      <%= form.collection_select :g_instrumento_id, GInstrumento.all, :id, :to_s, { include_blank: "Selecione um instrumento..." }, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :g_naipe_id %>
      <%= form.collection_select :g_naipe_id, GNaipe.all, :id, :to_s, { include_blank: "Selecione um naipe..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", g_instrumento_naipe_path(@g_instrumento_naipe), class: "secondary-button" if g_instrumento_naipe.persisted? %>
    <%= link_to "Cancelar", g_instrumentos_naipes_path, class: "secondary-button" unless g_instrumento_naipe.persisted? %>
  </div>
<% end %>
