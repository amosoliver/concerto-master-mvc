<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MPessoaFuncao.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_m_pessoa_funcao_path(@m_pessoa_funcao), class: "primary-button" %>
      <%= link_to "Voltar", m_pessoas_funcoes_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= MPessoaFuncao.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= MPessoaFuncao.human_attribute_name(:g_pessoa_id) %></span>
        <span class="detail-value"><%= @m_pessoa_funcao.g_pessoa %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= MPessoaFuncao.human_attribute_name(:u_funcao_id) %></span>
        <span class="detail-value"><%= @m_pessoa_funcao.u_funcao %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= MPessoaFuncao.human_attribute_name(:principal) %></span>
        <span class="detail-value"><%= @m_pessoa_funcao.principal %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@m_pessoa_funcao.created_at) %></span>
      <span>Atualizado em <%= l(@m_pessoa_funcao.updated_at) %></span>
    </div>
  </section>
</div>
