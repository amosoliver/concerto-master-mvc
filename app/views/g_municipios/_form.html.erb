<%= form_with(model: g_municipio, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: g_municipio %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :codigo_ibge %>
      <%= form.text_field :codigo_ibge, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :g_estado_id %>
      <%= form.collection_select :g_estado_id, GEstado.all, :id, :to_s, { include_blank: "Selecione um estado..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", g_municipio_path(@g_municipio), class: "secondary-button" if g_municipio.persisted? %>
    <%= link_to "Cancelar", g_municipios_path, class: "secondary-button" unless g_municipio.persisted? %>
  </div>
<% end %>
