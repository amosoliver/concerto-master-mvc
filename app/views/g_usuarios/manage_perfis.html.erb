<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciar</p>
      <h1>Acessos e perfis do usuário</h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Novo perfil", new_u_perfil_path, class: "secondary-button" if allowed_path?(new_u_perfil_path, method: :get) %>
      <%= link_to "Voltar", g_usuario_path(@g_usuario), class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Usuário</p>
        <h3><%= @g_usuario %></h3>
      </div>
    </div>
    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label">Pessoa</span>
        <span class="detail-value"><%= @g_usuario.g_pessoa %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label">Entidade base</span>
        <span class="detail-value"><%= @g_usuario.g_pessoa.g_entidade %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label">Entidades disponíveis aqui</span>
        <span class="detail-value"><%= @available_entities.size %></span>
      </div>
    </div>
  </section>

  <%= form_with url: update_perfis_g_usuario_path(@g_usuario), method: :patch, class: "panel-card form-card" do |form| %>
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Associação</p>
        <h3>Perfis por entidade</h3>
      </div>
    </div>

    <% if @available_entities.any? && @u_perfis.any? %>
      <div class="entity-access-stack">
        <% @available_entities.each do |entidade| %>
          <% selected_ids = Array(@selected_accesses[entidade.id]).map(&:to_i) %>
          <section class="entity-access-card">
            <div class="entity-access-card__header">
              <div>
                <h4><%= entidade %></h4>
                <p>Marque um ou mais perfis para liberar este usuário nessa entidade.</p>
              </div>
              <span class="entity-access-card__count"><%= pluralize(selected_ids.size, "perfil") %></span>
            </div>

            <div class="selection-panel">
              <div class="selection-group">
                <div class="selection-group__items">
                  <% @u_perfis.each do |perfil| %>
                    <label class="selection-item">
                      <%= check_box_tag "entity_profile_ids[#{entidade.id}][]", perfil.id, selected_ids.include?(perfil.id), id: "entity_#{entidade.id}_perfil_#{perfil.id}" %>
                      <span><%= perfil.descricao %></span>
                    </label>
                  <% end %>
                </div>
              </div>
            </div>
          </section>
        <% end %>
      </div>
    <% elsif @u_perfis.blank? %>
      <div class="empty-card">Nenhum perfil cadastrado. Crie perfis em <%= link_to "Perfis", u_perfis_path %> primeiro.</div>
    <% else %>
      <div class="empty-card">Nenhuma entidade disponível na área atual para conceder acesso a este usuário.</div>
    <% end %>

    <div class="form-actions">
      <%= form.submit "Salvar acessos", class: "primary-button" %>
      <%= link_to "Cancelar", g_usuario_path(@g_usuario), class: "secondary-button" %>
    </div>
  <% end %>
</div>
