<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Primeiro acesso</p>
      <h1>Defina sua nova senha</h1>
    </div>
  </div>

  <%= form_for(resource, as: resource_name, url: g_usuario_registration_path, html: { method: :put, class: "panel-card form-card" }) do |f| %>
    <% if resource.errors.any? %>
      <div class="alert alert-danger">
        <h2><%= pluralize(resource.errors.count, "erro") %> impediram o salvamento:</h2>
        <ul>
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-grid">
      <div class="field-group">
        <%= f.label :password, "Nova senha" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
      </div>

      <div class="field-group">
        <%= f.label :password_confirmation, "Confirmar nova senha" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit "Salvar nova senha", class: "primary-button" %>
    </div>
  <% end %>
</div>
