<%= form_with(model: g_usuario, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: g_usuario %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :email %>
      <%= form.text_field :email, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :password, g_usuario.persisted? ? "Senha (deixe em branco para manter)" : "Senha" %>
      <%= form.password_field :password, class: "form-control", autocomplete: "new-password" %>
    </div>
    <div class="field-group">
      <%= form.label :password_confirmation, "Confirmar senha" %>
      <%= form.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>
    <div class="field-group">
      <%= form.label :ativo %>
      <label class="checkbox-field">
        <%= form.check_box :ativo %>
        <span class="checkbox-field__label">Usuário ativo</span>
      </label>
    </div>
    <div class="field-group">
      <%= form.label :g_pessoa_id %>
      <%= form.collection_select :g_pessoa_id, tenant_pessoa_scope, :id, :to_s, { include_blank: "Selecione uma pessoa..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", g_usuario_path(@g_usuario), class: "secondary-button" if g_usuario.persisted? %>
    <%= link_to "Cancelar", g_usuarios_path, class: "secondary-button" unless g_usuario.persisted? %>
  </div>
<% end %>
