<%= form_with(model: m_grupo, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: m_grupo %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control", data: { controller: "uppercase" } %>
    </div>
    <div class="field-group">
      <label>Entidade</label>
      <div class="form-control form-control--static"><%= current_context_entidade || "Sem entidade vinculada" %></div>
    </div>
    <div class="field-group">
      <%= form.label :m_tipo_grupo_id %>
      <%= form.collection_select :m_tipo_grupo_id, MTipoGrupo.all, :id, :to_s, { include_blank: "Selecione um tipo de grupo..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", m_grupo_path(@m_grupo), class: "secondary-button" if m_grupo.persisted? %>
    <%= link_to "Cancelar", m_grupos_path, class: "secondary-button" unless m_grupo.persisted? %>
  </div>
<% end %>
