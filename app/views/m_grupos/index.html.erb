<div class="page-shell" data-controller="filters" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(MGrupo) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <span aria-hidden="true">🔎</span> Filtros
      </button>
      <%= authorized_link_to "Novo #{MGrupo.model_name.human}", new_m_grupo_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: m_grupos_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= MGrupo.human_attribute_name(:descricao) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :descricao_cont, placeholder: MGrupo.human_attribute_name(:descricao), "aria-label": MGrupo.human_attribute_name(:descricao), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MGrupo.human_attribute_name(:g_entidade_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_entidade_id_eq, options_from_collection_for_select(tenant_entity_scope, :id, :to_s, @q&.send(:g_entidade_id_eq)), { include_blank: true }, "aria-label": MGrupo.human_attribute_name(:g_entidade_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MGrupo.human_attribute_name(:m_tipo_grupo_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :m_tipo_grupo_id_eq, options_from_collection_for_select(MTipoGrupo.all, :id, :to_s, @q&.send(:m_tipo_grupo_id_eq)), { include_blank: true }, "aria-label": MGrupo.human_attribute_name(:m_tipo_grupo_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", m_grupos_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card panel-card--fill" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Resultados</p>
        <h3><%= pagy_count_label(@pagy) %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= MGrupo.human_attribute_name(:descricao) %></th>
            <th scope="col"><%= MGrupo.human_attribute_name(:g_entidade_id) %></th>
            <th scope="col"><%= MGrupo.human_attribute_name(:m_tipo_grupo_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @m_grupos.each do |m_grupo| %>
            <tr>
              <td><%= m_grupo.descricao %></td>
              <td><%= m_grupo.g_entidade %></td>
              <td><%= m_grupo.m_tipo_grupo %></td>
              <td>
                <%= render "shared/actions_menu", show_path: m_grupo_path(m_grupo), edit_path: edit_m_grupo_path(m_grupo), delete_path: m_grupo_path(m_grupo), config_path: manage_m_grupo_path(m_grupo) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @m_grupos.each do |m_grupo| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= MGrupo.human_attribute_name(:descricao) %></span>
            <span class="detail-value"><%= m_grupo.descricao %></span>
            <span class="detail-label"><%= MGrupo.human_attribute_name(:g_entidade_id) %></span>
            <span class="detail-value"><%= m_grupo.g_entidade %></span>
            <span class="detail-label"><%= MGrupo.human_attribute_name(:m_tipo_grupo_id) %></span>
            <span class="detail-value"><%= m_grupo.m_tipo_grupo %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: m_grupo_path(m_grupo), edit_path: edit_m_grupo_path(m_grupo), delete_path: m_grupo_path(m_grupo), config_path: manage_m_grupo_path(m_grupo) %>
          </div>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
