<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MGrupo.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_m_grupo_path(@m_grupo), class: "primary-button" %>
      <%= link_to "Voltar", m_grupos_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= MGrupo.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= MGrupo.human_attribute_name(:descricao) %></span>
        <span class="detail-value"><%= @m_grupo.descricao %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= MGrupo.human_attribute_name(:g_entidade_id) %></span>
        <span class="detail-value"><%= @m_grupo.g_entidade %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= MGrupo.human_attribute_name(:m_tipo_grupo_id) %></span>
        <span class="detail-value"><%= @m_grupo.m_tipo_grupo %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@m_grupo.created_at) %></span>
      <span>Atualizado em <%= l(@m_grupo.updated_at) %></span>
    </div>
  </section>
</div>
