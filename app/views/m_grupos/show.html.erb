<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MGrupo.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Gerenciar", manage_m_grupo_path(@m_grupo), class: "primary-button" %>
      <%= authorized_link_to "Editar", edit_m_grupo_path(@m_grupo), class: "primary-button" %>
      <%= link_to "Voltar", m_grupos_path, class: "secondary-button" %>
    </div>
  </div>

  <div class="show-stack">
    <div class="show-hero">
      <section class="panel-card show-summary">
        <p class="eyebrow">Grupo</p>
        <h2 class="show-summary__title"><%= @m_grupo.descricao %></h2>
        <p class="show-summary__text">Grupo do tipo <%= @m_grupo.m_tipo_grupo %> vinculado a <%= @m_grupo.g_entidade %>.</p>
      </section>

      <section class="panel-card show-section">
        <div class="panel-card__header">
          <div>
            <p class="eyebrow">Resumo</p>
            <h3>Composição</h3>
          </div>
        </div>
        <div class="show-stats">
          <div class="show-stat">
            <span class="show-stat__label">Pessoas</span>
            <span class="show-stat__value"><%= @m_grupo.g_pessoas.count %></span>
          </div>
          <div class="show-stat">
            <span class="show-stat__label">Instrumentos</span>
            <span class="show-stat__value"><%= @m_grupo.g_instrumentos_naipes.count %></span>
          </div>
        </div>
      </section>
    </div>

    <section class="panel-card detail-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Informações</p>
          <h3><%= MGrupo.model_name.human %></h3>
        </div>
      </div>

      <div class="detail-grid">
        <div class="detail-tile">
          <span class="detail-label"><%= MGrupo.human_attribute_name(:descricao) %></span>
          <span class="detail-value"><%= @m_grupo.descricao %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MGrupo.human_attribute_name(:g_entidade_id) %></span>
          <span class="detail-value"><%= @m_grupo.g_entidade %></span>
        </div>
        <div class="detail-tile">
          <span class="detail-label"><%= MGrupo.human_attribute_name(:m_tipo_grupo_id) %></span>
          <span class="detail-value"><%= @m_grupo.m_tipo_grupo %></span>
        </div>
      </div>
    </section>

    <section class="panel-card show-section">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Instrumentação</p>
          <h3>Instrumentos permitidos</h3>
        </div>
        <span class="show-section__count"><%= @m_grupo.g_instrumentos_naipes.count %></span>
      </div>
      <% if @m_grupo.g_instrumentos_naipes.any? %>
        <div class="tag-cloud">
          <% @m_grupo.g_instrumentos_naipes.each do |instrumento| %>
            <%= link_to instrumento.to_s, g_instrumento_naipe_path(instrumento), class: "tag-cloud__item tag-cloud__item--link" %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Nenhum instrumento permitido configurado para este grupo.</div>
      <% end %>
    </section>

    <section class="panel-card show-section">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Pessoas</p>
          <h3>Membros do grupo</h3>
        </div>
        <span class="show-section__count"><%= @m_grupo.g_pessoas.count %></span>
      </div>
      <% if @m_grupo.g_pessoas.any? %>
        <div class="related-grid">
          <% @m_grupo.g_pessoas.each do |pessoa| %>
            <article class="related-card">
              <span class="related-card__label"><%= pessoa.g_sexo %></span>
              <%= link_to pessoa.nome, g_pessoa_path(pessoa), class: "related-card__value related-card__value--link" %>
              <span class="related-card__meta"><%= pessoa.email.presence || format_cpf(pessoa.cpf) %></span>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-card">Nenhuma pessoa vinculada a este grupo.</div>
      <% end %>
    </section>
  </div>
</div>
