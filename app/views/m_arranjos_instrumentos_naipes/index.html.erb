<div class="page-shell" data-controller="filters" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(MArranjoInstrumentoNaipe) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <span aria-hidden="true">🔎</span> Filtros
      </button>
      <%= link_to "Novo #{MArranjoInstrumentoNaipe.model_name.human}", new_m_arranjo_instrumento_naipe_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: m_arranjos_instrumentos_naipes_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= MArranjoInstrumentoNaipe.human_attribute_name(:g_instrumento_naipe_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_instrumento_naipe_id_eq, options_from_collection_for_select(GInstrumentoNaipe.all, :id, :to_s, @q&.send(:g_instrumento_naipe_id_eq)), { include_blank: true }, "aria-label": MArranjoInstrumentoNaipe.human_attribute_name(:g_instrumento_naipe_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= MArranjoInstrumentoNaipe.human_attribute_name(:m_arranjo_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :m_arranjo_id_eq, options_from_collection_for_select(MArranjo.all, :id, :to_s, @q&.send(:m_arranjo_id_eq)), { include_blank: true }, "aria-label": MArranjoInstrumentoNaipe.human_attribute_name(:m_arranjo_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", m_arranjos_instrumentos_naipes_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@m_arranjos_instrumentos_naipes.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= MArranjoInstrumentoNaipe.human_attribute_name(:g_instrumento_naipe_id) %></th>
            <th scope="col"><%= MArranjoInstrumentoNaipe.human_attribute_name(:m_arranjo_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @m_arranjos_instrumentos_naipes.each do |m_arranjo_instrumento_naipe| %>
            <tr>
              <td><%= m_arranjo_instrumento_naipe.g_instrumento_naipe %></td>
              <td><%= m_arranjo_instrumento_naipe.m_arranjo %></td>
              <td>
                <%= render "shared/actions_menu", show_path: m_arranjo_instrumento_naipe_path(m_arranjo_instrumento_naipe), edit_path: edit_m_arranjo_instrumento_naipe_path(m_arranjo_instrumento_naipe), delete_path: m_arranjo_instrumento_naipe_path(m_arranjo_instrumento_naipe) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @m_arranjos_instrumentos_naipes.each do |m_arranjo_instrumento_naipe| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= MArranjoInstrumentoNaipe.human_attribute_name(:g_instrumento_naipe_id) %></span>
            <span class="detail-value"><%= m_arranjo_instrumento_naipe.g_instrumento_naipe %></span>
            <span class="detail-label"><%= MArranjoInstrumentoNaipe.human_attribute_name(:m_arranjo_id) %></span>
            <span class="detail-value"><%= m_arranjo_instrumento_naipe.m_arranjo %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: m_arranjo_instrumento_naipe_path(m_arranjo_instrumento_naipe), edit_path: edit_m_arranjo_instrumento_naipe_path(m_arranjo_instrumento_naipe), delete_path: m_arranjo_instrumento_naipe_path(m_arranjo_instrumento_naipe) %>
          </div>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
