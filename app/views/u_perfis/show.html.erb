<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= UPerfil.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_u_perfil_path(@u_perfil), class: "primary-button" %>
      <%= link_to "Voltar", u_perfis_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= UPerfil.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= UPerfil.human_attribute_name(:descricao) %></span>
        <span class="detail-value"><%= @u_perfil.descricao %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@u_perfil.created_at) %></span>
      <span>Atualizado em <%= l(@u_perfil.updated_at) %></span>
    </div>
  </section>
</div>
