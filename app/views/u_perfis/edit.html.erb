<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Acesso</p>
      <h1><%= @u_perfil.descricao %></h1>
    </div>
    <div class="page-header__actions">
      <% can_edit = allowed_path?(edit_u_perfil_path(@u_perfil), method: :get) %>
      <% can_delete = allowed_path?(u_perfil_path(@u_perfil), method: :delete) %>
      <% if can_edit || can_delete %>
        <div class="actions-menu" data-controller="dropdown">
          <button type="button" class="primary-button" data-dropdown-target="button" data-action="click->dropdown#toggle" aria-haspopup="true" aria-expanded="false">
            Ações
          </button>
          <div class="actions-menu__panel" data-dropdown-target="panel" hidden>
            <%= authorized_link_to edit_u_perfil_path(@u_perfil), class: "actions-menu__item" do %><%= ui_icon(:pencil, size: 16) %> Atualizar perfil<% end if can_edit %>
            <%= authorized_link_to edit_u_perfil_path(@u_perfil, section: "funcoes"), class: "actions-menu__item" do %><%= ui_icon(:id, size: 16) %> Gerir funções<% end if can_edit %>
            <%= authorized_link_to edit_u_perfil_path(@u_perfil, section: "permissoes"), class: "actions-menu__item" do %><%= ui_icon(:shield_lock, size: 16) %> Gerir permissões<% end if can_edit %>
            <%= authorized_button_to u_perfil_path(@u_perfil), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "actions-menu__item actions-menu__item--danger" do %><%= ui_icon(:trash, size: 16) %> Excluir<% end if can_delete %>
          </div>
        </div>
      <% end %>
      <%= link_to "Voltar", u_perfis_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Gestão</p>
        <h3><%= section_title(params[:section]) %></h3>
      </div>
    </div>

    <%= render "form", u_perfil: @u_perfil, u_permissoes: @u_permissoes, u_funcoes: @u_funcoes %>
  </section>
</div>
