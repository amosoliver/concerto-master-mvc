<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(UPerfil) %></h1>
    </div>
    <div class="page-header__actions">
      <%= link_to "Novo #{UPerfil.model_name.human}", new_u_perfil_path, class: "primary-button" %>
    </div>
  </div>

  <%= search_form_for @q, url: u_perfis_path, method: :get, class: "search-panel" do |f| %>
    <div class="search-input">
      <span aria-hidden="true">🔎</span>
      <%= f.search_field :descricao_cont, placeholder: UPerfil.human_attribute_name(:descricao), "aria-label": UPerfil.human_attribute_name(:descricao), class: "search-input__field" %>
    </div>
    <div class="search-panel__actions">
      <%= f.submit "Filtrar", class: "primary-button" %>
      <%= link_to "Limpar", u_perfis_path, class: "secondary-button" %>
    </div>
  <% end %>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@u_perfis.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= UPerfil.human_attribute_name(:descricao) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @u_perfis.each do |u_perfil| %>
            <tr>
              <td><%= u_perfil.descricao %></td>
              <td>
                <%= render "shared/actions_menu", show_path: u_perfil_path(u_perfil), edit_path: edit_u_perfil_path(u_perfil), delete_path: u_perfil_path(u_perfil) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @u_perfis.each do |u_perfil| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= UPerfil.human_attribute_name(:descricao) %></span>
            <span class="detail-value"><%= u_perfil.descricao %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: u_perfil_path(u_perfil), edit_path: edit_u_perfil_path(u_perfil), delete_path: u_perfil_path(u_perfil) %>
          </div>
        </article>
      <% end %>
    </div>

    <% if @pagy %>
      <div class="pagination-wrap">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  </section>
</div>
