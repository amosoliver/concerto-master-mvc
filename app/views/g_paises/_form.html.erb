<%= form_with(model: g_pais, local: true, class: "panel-card form-card") do |form| %>
  <%= render "shared/form_errors", record: g_pais %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :descricao %>
      <%= form.text_field :descricao, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", g_pais_path(@g_pais), class: "secondary-button" if g_pais.persisted? %>
    <%= link_to "Cancelar", g_paises_path, class: "secondary-button" unless g_pais.persisted? %>
  </div>
<% end %>
