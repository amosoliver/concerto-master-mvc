<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1>Exemplo</h1>
    </div>
    <div class="page-header__actions">
      <%= link_to "Editar", edit_example_path(@example), class: "primary-button" %>
      <%= link_to "Voltar", examples_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3>Exemplo</h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label">Nome</span>
        <span class="detail-value"><%= @example.name %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label">Descrição</span>
        <span class="detail-value"><%= @example.description %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@example.created_at) %></span>
      <span>Atualizado em <%= l(@example.updated_at) %></span>
    </div>
  </section>
</div>
