<%= form_with(model: @example, class: "panel-card form-card") do |form| %>
  <%= render "shared/form_errors", record: @example %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :name, "Nome" %>
      <%= form.text_field :name, class: "form-control", data: { controller: "uppercase" } %>
    </div>

    <div class="field-group field-group--full">
      <%= form.label :description, "Descrição" %>
      <%= form.text_area :description, rows: 5, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", @example.persisted? ? example_path(@example) : examples_path, class: "secondary-button" %>
  </div>
<% end %>
