<div class="page-shell" data-controller="filters" data-filters-active-value="<%= request.query_parameters.except("page").present? %>">
  <div class="page-header">
    <div>
      <p class="eyebrow">Gerenciamento</p>
      <h1><%= model_plural_human_name(GPessoa) %></h1>
    </div>
    <div class="page-header__actions">
      <button type="button" class="filter-toggle" data-filters-target="toggleButton" data-action="click->filters#toggle" aria-expanded="false">
        <span aria-hidden="true">🔎</span> Filtros
      </button>
      <%= authorized_link_to "Novo #{GPessoa.model_name.human}", new_g_pessoa_path, class: "primary-button" %>
    </div>
  </div>

  <div class="search-panel" data-filters-target="panel" hidden>
    <%= search_form_for @q, url: g_pessoas_path, method: :get do |f| %>
      <div class="search-grid">
        <div class="search-field">
          <label><%= GPessoa.human_attribute_name(:nome) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :nome_cont, placeholder: GPessoa.human_attribute_name(:nome), "aria-label": GPessoa.human_attribute_name(:nome), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPessoa.human_attribute_name(:email) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :email_cont, placeholder: GPessoa.human_attribute_name(:email), "aria-label": GPessoa.human_attribute_name(:email), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPessoa.human_attribute_name(:cpf) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.search_field :cpf_cont, placeholder: GPessoa.human_attribute_name(:cpf), "aria-label": GPessoa.human_attribute_name(:cpf), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPessoa.human_attribute_name(:g_entidade_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_entidade_id_eq, options_from_collection_for_select(tenant_entity_scope, :id, :to_s, @q&.send(:g_entidade_id_eq)), { include_blank: true }, "aria-label": GPessoa.human_attribute_name(:g_entidade_id), class: "search-input__field" %>
          </div>
        </div>
        <div class="search-field">
          <label><%= GPessoa.human_attribute_name(:g_sexo_id) %></label>
          <div class="search-input">
            <span aria-hidden="true">🔎</span>
            <%= f.select :g_sexo_id_eq, options_from_collection_for_select(GSexo.all, :id, :to_s, @q&.send(:g_sexo_id_eq)), { include_blank: true }, "aria-label": GPessoa.human_attribute_name(:g_sexo_id), class: "search-input__field" %>
          </div>
        </div>
      </div>
      <div class="search-panel__actions">
        <%= f.submit "Filtrar", class: "primary-button" %>
        <%= link_to "Limpar", g_pessoas_path, class: "secondary-button" %>
      </div>
    <% end %>
  </div>

  <section class="panel-card" data-controller="view-toggle">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Listagem</p>
        <h3><%= pluralize(@g_pessoas.size, "registro") %></h3>
      </div>
      <div class="view-switch">
        <button type="button" class="view-switch__btn is-active" data-view-toggle-target="tableButton" data-action="click->view-toggle#showTable">☰ Tabela</button>
        <button type="button" class="view-switch__btn" data-view-toggle-target="cardsButton" data-action="click->view-toggle#showCards">▦ Cards</button>
      </div>
    </div>

    <div class="table-wrapper" data-view-toggle-target="table">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col"><%= GPessoa.human_attribute_name(:nome) %></th>
            <th scope="col"><%= GPessoa.human_attribute_name(:email) %></th>
            <th scope="col"><%= GPessoa.human_attribute_name(:cpf) %></th>
            <th scope="col"><%= GPessoa.human_attribute_name(:g_entidade_id) %></th>
            <th scope="col"><%= GPessoa.human_attribute_name(:g_sexo_id) %></th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @g_pessoas.each do |g_pessoa| %>
            <tr>
              <td><%= g_pessoa.nome %></td>
              <td><%= g_pessoa.email %></td>
              <td><%= format_cpf(g_pessoa.cpf) %></td>
              <td><%= g_pessoa.g_entidade %></td>
              <td><%= g_pessoa.g_sexo %></td>
              <td>
                <%= render "shared/actions_menu", show_path: g_pessoa_path(g_pessoa), edit_path: edit_g_pessoa_path(g_pessoa), delete_path: g_pessoa_path(g_pessoa) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card-grid" data-view-toggle-target="cards" hidden>
      <% @g_pessoas.each do |g_pessoa| %>
        <article class="record-card">
          <div class="record-card__body">
            <span class="detail-label"><%= GPessoa.human_attribute_name(:nome) %></span>
            <span class="detail-value"><%= g_pessoa.nome %></span>
            <span class="detail-label"><%= GPessoa.human_attribute_name(:email) %></span>
            <span class="detail-value"><%= g_pessoa.email %></span>
            <span class="detail-label"><%= GPessoa.human_attribute_name(:cpf) %></span>
            <span class="detail-value"><%= format_cpf(g_pessoa.cpf) %></span>
            <span class="detail-label"><%= GPessoa.human_attribute_name(:g_entidade_id) %></span>
            <span class="detail-value"><%= g_pessoa.g_entidade %></span>
            <span class="detail-label"><%= GPessoa.human_attribute_name(:g_sexo_id) %></span>
            <span class="detail-value"><%= g_pessoa.g_sexo %></span>
          </div>
          <div class="record-card__footer">
            <%= render "shared/actions_menu", show_path: g_pessoa_path(g_pessoa), edit_path: edit_g_pessoa_path(g_pessoa), delete_path: g_pessoa_path(g_pessoa) %>
          </div>
        </article>
      <% end %>
    </div>

    <%= render "layouts/pagination", pagy: @pagy %>
  </section>
</div>
