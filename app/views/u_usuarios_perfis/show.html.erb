<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= UUsuarioPerfil.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= authorized_link_to "Editar", edit_u_usuario_perfil_path(@u_usuario_perfil), class: "primary-button" %>
      <%= link_to "Voltar", u_usuarios_perfis_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= UUsuarioPerfil.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= UUsuarioPerfil.human_attribute_name(:u_perfil_id) %></span>
        <span class="detail-value"><%= @u_usuario_perfil.u_perfil %></span>
      </div>
      <div class="detail-tile">
        <span class="detail-label"><%= UUsuarioPerfil.human_attribute_name(:g_usuario_id) %></span>
        <span class="detail-value"><%= @u_usuario_perfil.g_usuario %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@u_usuario_perfil.created_at) %></span>
      <span>Atualizado em <%= l(@u_usuario_perfil.updated_at) %></span>
    </div>
  </section>
</div>
