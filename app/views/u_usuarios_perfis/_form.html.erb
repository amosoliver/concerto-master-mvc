<%= form_with(model: u_usuario_perfil, local: true, class: "panel-card form-card", data: { controller: "select" }) do |form| %>
  <%= render "shared/form_errors", record: u_usuario_perfil %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :u_perfil_id %>
      <%= form.collection_select :u_perfil_id, UPerfil.all, :id, :to_s, { include_blank: "Selecione um perfil..." }, class: "form-control" %>
    </div>
    <div class="field-group">
      <%= form.label :g_usuario_id %>
      <% usuarios = @selected_g_usuario.present? ? [@selected_g_usuario] : GUsuario.all %>
      <%= form.collection_select :g_usuario_id, usuarios, :id, :to_s, { include_blank: @selected_g_usuario.present? ? false : "Selecione um usuário..." }, class: "form-control" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancelar", u_usuario_perfil_path(@u_usuario_perfil), class: "secondary-button" if u_usuario_perfil.persisted? %>
    <%= link_to "Cancelar", u_usuarios_perfis_path, class: "secondary-button" unless u_usuario_perfil.persisted? %>
  </div>
<% end %>
