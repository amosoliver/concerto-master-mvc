<% snapshot = local_assigns.fetch(:snapshot) %>
<% view = snapshot[:view] %>
<% base_params = local_assigns[:base_params] || {} %>
<% base_path = local_assigns.fetch(:base_path) %>
<% build_calendar_path = lambda do |overrides|
     query = base_params.merge(overrides).to_query
     query.present? ? "#{base_path}?#{query}" : base_path
   end %>

<section class="panel-card calendar-card">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Agenda da entidade</p>
      <h3><%= calendar_period_label(view, snapshot) %></h3>
    </div>
    <div class="calendar-card__actions">
      <%= link_to "Hoje", build_calendar_path.call(snapshot[:nav][:today]), class: "secondary-button" %>
      <%= link_to "◀", build_calendar_path.call(snapshot[:nav][:prev]), class: "secondary-button secondary-button--icon", aria: { label: "Período anterior" } %>
      <%= link_to "▶", build_calendar_path.call(snapshot[:nav][:next]), class: "secondary-button secondary-button--icon", aria: { label: "Próximo período" } %>
    </div>
  </div>

  <div class="view-switch calendar-view-switch">
    <%= link_to "Mês", build_calendar_path.call(view: "month", month: snapshot[:nav][:switch_month]), class: "view-switch__btn #{"is-active" if view == "month"}" %>
    <%= link_to "Semana", build_calendar_path.call(view: "week", date: snapshot[:nav][:switch_date]), class: "view-switch__btn #{"is-active" if view == "week"}" %>
    <%= link_to "Dia", build_calendar_path.call(view: "day", date: snapshot[:nav][:switch_date]), class: "view-switch__btn #{"is-active" if view == "day"}" %>
  </div>

  <% if view == "week" %>
    <div class="calendar-week">
      <% snapshot[:week_days].each do |day| %>
        <% day_events = snapshot[:events_by_day][day] || [] %>
        <article class="calendar-week__day <%= "is-today" if day == Time.zone.today %>">
          <header class="calendar-week__day-header">
            <span class="calendar-week__weekday"><%= calendar_weekday_label(day).first(3) %></span>
            <%= link_to day.day, build_calendar_path.call(view: "day", date: day.strftime(DashboardResumoService::DATE_FORMAT)), class: "calendar-week__day-number" %>
          </header>

          <div class="calendar-week__events">
            <% if day_events.any? %>
              <% day_events.each do |evento| %>
                <%= link_to m_evento_path(evento), class: "calendar-event-pill" do %>
                  <strong><%= format_time(evento.data_inicio) %></strong>
                  <span><%= evento.descricao %></span>
                <% end %>
              <% end %>
            <% else %>
              <span class="calendar-day__empty">Sem eventos</span>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>

  <% elsif view == "day" %>
    <div class="calendar-day-agenda">
      <% if snapshot[:day_events].any? %>
        <ul class="event-list">
          <% snapshot[:day_events].each do |evento| %>
            <li>
              <%= link_to m_evento_path(evento), class: "event-list__link" do %>
                <span>
                  <strong><%= evento.descricao %></strong><br>
                  <small><%= evento.g_predio %></small>
                </span>
                <strong><%= format_time(evento.data_inicio) %></strong>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-card">Nenhum evento neste dia.</div>
      <% end %>
    </div>

  <% else %>
    <div class="calendar-grid calendar-grid--weekdays">
      <% %w[Seg Ter Qua Qui Sex Sab Dom].each do |weekday| %>
        <span class="calendar-grid__weekday"><%= weekday %></span>
      <% end %>
    </div>

    <div class="calendar-grid calendar-grid--days">
      <% snapshot[:calendar_weeks].each do |week| %>
        <% week.each do |day| %>
          <% day_events = snapshot[:events_by_day][day] || [] %>
          <%= link_to build_calendar_path.call(view: "day", date: day.strftime(DashboardResumoService::DATE_FORMAT)),
                class: "calendar-day #{"is-outside" if day.month != snapshot[:month_start].month} #{"is-today" if day == Time.zone.today}" do %>
            <span class="calendar-day__number"><%= day.day %></span>
            <% if day_events.any? %>
              <span class="calendar-day__badge"><%= day_events.size %></span>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
