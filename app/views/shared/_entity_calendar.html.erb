<% snapshot = local_assigns.fetch(:snapshot) %>
<% view = snapshot[:view] %>
<% base_params = local_assigns[:base_params] || {} %>
<% base_path = local_assigns.fetch(:base_path) %>
<% build_calendar_path = lambda do |overrides|
     query = base_params.merge(overrides).to_query
     query.present? ? "#{base_path}?#{query}" : base_path
   end %>

<section class="panel-card calendar-card">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Agenda da entidade</p>
      <h3><%= calendar_period_label(view, snapshot) %></h3>
    </div>
    <div class="calendar-card__actions">
      <%= link_to "Hoje", build_calendar_path.call(snapshot[:nav][:today]), class: "secondary-button" %>
      <%= link_to "◀", build_calendar_path.call(snapshot[:nav][:prev]), class: "secondary-button secondary-button--icon", aria: { label: "Período anterior" } %>
      <%= link_to "▶", build_calendar_path.call(snapshot[:nav][:next]), class: "secondary-button secondary-button--icon", aria: { label: "Próximo período" } %>
    </div>
  </div>

  <div class="view-switch calendar-view-switch">
    <%= link_to "Mês", build_calendar_path.call(view: "month", month: snapshot[:nav][:switch_month]), class: "view-switch__btn #{"is-active" if view == "month"}" %>
    <%= link_to "Semana", build_calendar_path.call(view: "week", date: snapshot[:nav][:switch_date]), class: "view-switch__btn #{"is-active" if view == "week"}" %>
    <%= link_to "Dia", build_calendar_path.call(view: "day", date: snapshot[:nav][:switch_date]), class: "view-switch__btn #{"is-active" if view == "day"}" %>
  </div>

  <% if view == "week" %>
    <div class="calendar-week">
      <% snapshot[:week_days].each do |day| %>
        <% day_entries = snapshot[:entries_by_day][day] || [] %>
        <% day_path = build_calendar_path.call(view: "day", date: day.strftime(DashboardResumoService::DATE_FORMAT)) %>
        <article
          class="calendar-week__day <%= "is-today" if day == Time.zone.today %>"
          data-controller="calendar-link"
          data-calendar-link-url-value="<%= day_path %>"
          data-action="click->calendar-link#open keydown->calendar-link#open"
          tabindex="0"
          role="link"
          aria-label="Abrir agenda de <%= l(day, format: "%d/%m/%Y") %>">
          <header class="calendar-week__day-header">
            <span class="calendar-week__weekday"><%= calendar_weekday_label(day).first(3) %></span>
            <%= link_to day.day, day_path, class: "calendar-week__day-number" %>
          </header>

          <div class="calendar-week__events">
            <% if day_entries.any? %>
              <% day_entries.each do |entry| %>
                <%= link_to calendar_entry_path(entry), class: "calendar-event-pill #{calendar_entry_css_class(entry)}" do %>
                  <strong><%= format_time(entry[:starts_at]) %></strong>
                  <span><%= calendar_entry_type_label(entry) %>: <%= entry[:title] %></span>
                <% end %>
              <% end %>
            <% else %>
              <span class="calendar-day__empty">Sem compromissos</span>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>

  <% elsif view == "day" %>
    <div class="calendar-day-agenda">
      <% if snapshot[:day_entries].any? %>
        <ul class="event-list">
          <% snapshot[:day_entries].each do |entry| %>
            <li>
              <%= link_to calendar_entry_path(entry), class: "event-list__link" do %>
                <span>
                  <strong><%= entry[:title] %></strong><br>
                  <small><%= calendar_entry_type_label(entry) %> • <%= entry[:location] %></small>
                </span>
                <strong><%= format_time(entry[:starts_at]) %></strong>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-card">Nenhum compromisso neste dia.</div>
      <% end %>
    </div>

  <% else %>
    <div class="calendar-grid calendar-grid--month">
      <% (snapshot[:month_start]..snapshot[:month_end]).each do |day| %>
          <% day_entries = snapshot[:entries_by_day][day] || [] %>
          <% day_path = build_calendar_path.call(view: "day", date: day.strftime(DashboardResumoService::DATE_FORMAT)) %>
          <article
            class="calendar-day <%= "has-events" if day_entries.any? %> <%= "is-today" if day == Time.zone.today %>"
            data-controller="calendar-link"
            data-calendar-link-url-value="<%= day_path %>"
            data-action="click->calendar-link#open keydown->calendar-link#open"
            tabindex="0"
            role="link"
            aria-label="Abrir agenda de <%= l(day, format: "%d/%m/%Y") %>">
            <div class="calendar-day__header">
              <div class="calendar-day__title">
                <span class="calendar-day__weekday"><%= calendar_weekday_label(day).first(3) %></span>
                <%= link_to day.day, day_path, class: "calendar-day__number" %>
              </div>
              <% if day_entries.any? %>
                <span class="calendar-day__badge"><%= day_entries.size %></span>
              <% end %>
            </div>

            <% if day_entries.any? %>
              <div class="calendar-day__events">
                <% day_entries.first(2).each do |entry| %>
                  <%= link_to calendar_entry_path(entry), class: "calendar-day__entry #{calendar_entry_css_class(entry)}" do %>
                    <strong><%= format_time(entry[:starts_at]) %></strong>
                    <span><%= entry[:title] %></span>
                  <% end %>
                <% end %>

                <% if day_entries.size > 2 %>
                  <%= link_to "+#{day_entries.size - 2} mais", day_path, class: "calendar-day__more" %>
                <% end %>
              </div>
            <% else %>
              <span class="calendar-day__empty">Sem compromissos</span>
            <% end %>
          </article>
      <% end %>
    </div>
  <% end %>
</section>
