<%# locals: (record:) %>
<% if record.errors.any? %>
  <section class="form-alert" aria-live="polite">
    <div class="form-alert__icon" aria-hidden="true">!</div>
    <div class="form-alert__content">
      <h2 class="form-alert__title">
        <%= pluralize(record.errors.count, "erro") %>
        <%= record.errors.count == 1 ? "impediu" : "impediram" %>
        o salvamento:
      </h2>
      <ul class="form-alert__list">
        <% record.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  </section>
<% end %>
