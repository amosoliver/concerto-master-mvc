<%# locals: (show_path:, edit_path:, delete_path:) %>
<% can_show = allowed_path?(show_path, method: :get) %>
<% can_edit = allowed_path?(edit_path, method: :get) %>
<% can_delete = allowed_path?(delete_path, method: :delete) %>

<% if can_show || can_edit || can_delete %>
  <div class="actions-menu" data-controller="dropdown">
    <button type="button" class="icon-button icon-button--sm" data-dropdown-target="button" data-action="click->dropdown#toggle" aria-haspopup="true" aria-expanded="false" aria-label="Ações">⚙️</button>
    <div class="actions-menu__panel" data-dropdown-target="panel" hidden>
      <%= authorized_link_to show_path, class: "actions-menu__item" do %><span aria-hidden="true">👁️</span> Ver<% end if can_show %>
      <%= authorized_link_to edit_path, class: "actions-menu__item" do %><span aria-hidden="true">✏️</span> Editar<% end if can_edit %>
      <%= authorized_button_to delete_path, method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "actions-menu__item actions-menu__item--danger" do %><span aria-hidden="true">🗑️</span> Excluir<% end if can_delete %>
    </div>
  </div>
<% end %>
