<div class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">Detalhes</p>
      <h1><%= MArranjador.model_name.human %></h1>
    </div>
    <div class="page-header__actions">
      <%= link_to "Editar", edit_m_arranjador_path(@m_arranjador), class: "primary-button" %>
      <%= link_to "Voltar", m_arranjadores_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="panel-card detail-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Informações</p>
        <h3><%= MArranjador.model_name.human %></h3>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-tile">
        <span class="detail-label"><%= MArranjador.human_attribute_name(:descricao) %></span>
        <span class="detail-value"><%= @m_arranjador.descricao %></span>
      </div>
    </div>

    <div class="detail-meta">
      <span>Criado em <%= l(@m_arranjador.created_at) %></span>
      <span>Atualizado em <%= l(@m_arranjador.updated_at) %></span>
    </div>
  </section>
</div>
